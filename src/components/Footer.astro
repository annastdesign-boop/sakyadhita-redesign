---
/**
 * Footer — gradient footer with brand, link columns, social icons,
 * and a newsletter signup box.
 *
 * NOTE: the newsletter box is not wired to a real mailing list yet
 * (the old site doesn't have one either). It currently just says
 * thanks. We'll connect it properly in a later step.
 */
const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="brand" href="/" style="color:var(--ink);">
          <span class="mark" aria-hidden="true"></span>
          <span class="wordmark">Sakyadhita</span>
        </a>
        <p>
          International Association of Buddhist Women. Connecting laywomen, monastics, and scholars
          across traditions since 1987.
        </p>
        <div class="social" aria-label="Social media">
          <a href="https://www.facebook.com/sakyadhita.international" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Facebook"
            ><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3l.4-3H14V4.2c0-.85.25-1.45 1.5-1.45H17V.1C16.7.05 15.8 0 14.7 0 12.4 0 10.8 1.4 10.8 4v2H8v3h2.8v8H14V9z"/></svg></a
          >
          <a href="https://www.youtube.com/@sakyadhitainternational" target="_blank" rel="noopener noreferrer" title="YouTube" aria-label="YouTube"
            ><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.5a3 3 0 0 0-2.1-2.1C19.5 4 12 4 12 4s-7.5 0-9.4.4A3 3 0 0 0 .5 6.5C.1 8.4.1 12 .1 12s0 3.6.4 5.5a3 3 0 0 0 2.1 2.1C4.5 20 12 20 12 20s7.5 0 9.4-.4a3 3 0 0 0 2.1-2.1c.4-1.9.4-5.5.4-5.5s0-3.6-.4-5.5zM9.6 15.5v-7l6.3 3.5-6.3 3.5z"/></svg></a
          >
          <a href="https://www.pinterest.com/sakyadhita/" target="_blank" rel="noopener noreferrer" title="Pinterest" aria-label="Pinterest"
            ><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12c0 5 3.1 9.3 7.5 11-.1-.9-.2-2.4 0-3.4l1.4-5.9s-.4-.7-.4-1.8c0-1.6.95-2.8 2.1-2.8 1 0 1.5.75 1.5 1.65 0 1-.65 2.5-.95 3.9-.3 1.15.6 2.1 1.7 2.1 2 0 3.6-2.15 3.6-5.2 0-2.7-1.95-4.6-4.7-4.6-3.2 0-5.1 2.4-5.1 4.9 0 .95.35 2 .85 2.55.1.1.1.2.1.3l-.3 1.3c0 .2-.15.3-.35.15-1.3-.6-2.1-2.5-2.1-4 0-3.3 2.4-6.3 6.9-6.3 3.6 0 6.4 2.6 6.4 6 0 3.6-2.25 6.5-5.4 6.5-1.05 0-2.05-.55-2.4-1.2l-.65 2.5c-.25.9-.9 2.05-1.3 2.75 1 .3 2.05.45 3.15.45 6.6 0 12-5.4 12-12S18.6 0 12 0z"/></svg></a
          >
          <a href="https://awakeningbuddhistwomen.blogspot.com/" target="_blank" rel="noopener noreferrer" title="Blog" aria-label="Blog"
            ><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.976 24H2.026C.9 24 0 23.1 0 21.976V2.026C0 .9.9 0 2.026 0h19.95C23.1 0 24 .9 24 2.026v19.95C24 23.1 23.1 24 21.976 24zM12.154 5.5H9.5C7.29 5.5 5.5 7.29 5.5 9.5v5c0 2.21 1.79 4 4 4h5c2.21 0 4-1.79 4-4v-2.846c0-.637-.517-1.154-1.154-1.154h-.847c-.581 0-1.06-.435-1.135-1.008C15.096 6.633 13.803 5.5 12.154 5.5zM9.6 8.5h2c.552 0 1 .448 1 1s-.448 1-1 1h-2c-.552 0-1-.448-1-1s.448-1 1-1zm4.8 7H9.6c-.552 0-1-.448-1-1s.448-1 1-1h4.8c.552 0 1 .448 1 1s-.448 1-1 1z"/></svg></a
          >
          <a href="https://www.goodreads.com/group/show/94269-women-in-buddhism" target="_blank" rel="noopener noreferrer" title="Goodreads" aria-label="Goodreads"
            ><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.43 23.995c-3.608-.208-6.274-2.077-6.448-5.078.695.007 1.416-.013 2.078.006.224 1.6 1.626 2.792 3.583 3.107 2.634.415 5.652-.297 6.098-3.983.264-2.184.03-3.183.03-4.196v-.35c-.941 2.29-2.746 3.583-5.28 3.583C7.256 17.077 4.5 13.7 4.5 9.75 4.5 5.752 7.36 2.42 11.62 2.42c2.634 0 4.196 1.334 5.15 3.35V2.72h1.977v13.834c0 4.802-2.516 7.19-7.31 7.44zm.204-19.622c-3.325 0-5.15 2.72-5.15 5.436 0 2.912 1.66 5.494 5.05 5.494 3.42 0 5.15-2.71 5.15-5.494 0-2.912-1.66-5.436-5.05-5.436z"/></svg></a
          >
        </div>
      </div>
      <div class="footer-col">
        <h4>Explore</h4>
        <ul>
          <li><a href="/conferences">Conferences</a></li>
          <li><a href="/publications">Resources</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/ordination-issue">Ordination</a></li>
          <li><a href="/branches">Branches</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Get Involved</h4>
        <ul>
          <li><a href="/join">Join</a></li>
          <li><a href="/volunteer">Volunteer</a></li>
          <li><a href="/donate">Donate</a></li>
          <li><a href="/conferences#host">Host a Conference</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="/contact">General inquiries</a></li>
          <li><a href="/branches">Branch contacts</a></li>
          <li><a href="/contact#press">Press &amp; partnerships</a></li>
          <li>7331 Princess View Dr<br />San Diego, CA 92120</li>
        </ul>
      </div>
      <div class="footer-news">
        <h4>Newsletter</h4>
        <p>One email a year — when the new issue drops.</p>
        <form id="footer-newsletter">
          <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-rule"></div>
    <div class="footer-bottom">
      <span
        >© {year} Sakyadhita International. This website is licensed under a
        <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer"
          >Creative Commons Attribution-NonCommercial-NoDerivs 4.0 International License</a
        >.</span
      >
    </div>
  </div>
</footer>

<script>
  // Placeholder behaviour until the newsletter is connected to a real list.
  const form = document.getElementById('footer-newsletter') as HTMLFormElement | null
  form?.addEventListener('submit', (e) => {
    e.preventDefault()
    form.querySelector('input')!.value = ''
    form.querySelector('button')!.textContent = 'Thanks ✓'
  })
</script>
