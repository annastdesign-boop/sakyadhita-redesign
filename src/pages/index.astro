---
/**
 * Home page — hero with photo marquee, impact numbers, mission pillars,
 * featured + past conferences, latest news, press logos, interactive
 * branches map, and the three ways to support.
 *
 * The map pins live in src/data/branches-map.json — edit there.
 * All editable copy lives in src/data/pages/home.json.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import homePage from '../data/pages/home.json'
// Fixed grid positions for the three support cards (glyph image is inline, from JSON)
const wayMods = ['way--join', 'way--vol', 'way--don']
const branchModules = import.meta.glob('../content/branches/*.json', { eager: true })
const homeSpots = Object.values(branchModules)
  .map((m: any) => m.default)
  .filter((b: any) => b.homeMap)
  .map((b: any) => ({
    name: b.name,
    kind: b.type,
    lat: b.lat,
    lng: b.lng,
    desc: b.homeDesc || b.desc,
    contact: b.contact,
  }))
const branchesMap = {
  kinds: { branch: 'National Branch', local: 'Local Chapter', partner: 'Partner' },
  spots: homeSpots,
}
---

<BaseLayout
  title={homePage.seo.title}
  description={homePage.seo.description}
  active="home"
  ogImage={homePage.seo.ogImage}
>
  <!-- HERO -->
  <section class="home-hero">
    <div class="content">
      <img class="hero-logo" src={homePage.hero.logo} alt={homePage.hero.logoAlt} />
      <h1>
        <span class="name">{homePage.hero.titleName}</span>
        <span class="full">{homePage.hero.titleFull}</span>
      </h1>
      {homePage.hero.announcement && <div class="eyebrow hero-announce">{homePage.hero.announcement}</div>}
      <p>
        {homePage.hero.text}
      </p>
      <div class="cta-row">
        <a class="btn btn--primary btn--lg" href={homePage.hero.primaryCta.href}>{homePage.hero.primaryCta.label} <span class="arr">→</span></a>
        <a class="btn btn--ghost btn--lg" href={homePage.hero.secondaryCta.href}>{homePage.hero.secondaryCta.label}</a>
      </div>
    </div>
    <div class="hero-marquee" aria-hidden="true">
      <div class="track">
        {homePage.hero.marquee.map((m, i) => {
          const img = <img src={m.img} alt="" style={m.focus ? `object-position: ${m.focus};` : undefined} loading={i === 0 ? 'eager' : undefined} />
          return m.href ? <a href={m.href} tabindex="-1">{img}</a> : img
        })}
        <!-- duplicate set for the seamless loop -->
        {homePage.hero.marquee.map((m) => {
          const img = <img src={m.img} alt="" style={m.focus ? `object-position: ${m.focus};` : undefined} />
          return m.href ? <a href={m.href} tabindex="-1">{img}</a> : img
        })}
      </div>
    </div>
    <p class="marquee-credit">
      {homePage.hero.credit.text + ' '}
      <a href={homePage.hero.credit.linkUrl} target="_blank" rel="noopener noreferrer">{homePage.hero.credit.linkLabel}</a>
    </p>
  </section>

  <!-- IMPACT NUMBERS -->
  <section>
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{homePage.stats.eyebrow}</div>
        <h2 class="h-section">{homePage.stats.heading}</h2>
      </div>
      <div class="stats-row">
        {homePage.stats.items.map((s) => (
          <div class="stat"><div class="h-stat">{s.value}</div><div class="lab">{s.label}</div></div>
        ))}
      </div>
    </div>
  </section>

  <!-- MISSION · THREE PILLARS -->
  <section class="mission-alt">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{homePage.mission.eyebrow}</div>
        <h2 class="h-section">{homePage.mission.heading}</h2>
        <div class="intro">
          <p>
            {homePage.mission.intro}
          </p>
        </div>
      </div>
      <div class="layout">
        <div class="pillar-card connect">
          <h3>{homePage.mission.pillars[0].title}</h3>
          <p>
            {homePage.mission.pillars[0].text}
          </p>
        </div>
        <div class="mandala" aria-hidden="true"></div>
        <div class="pillar-card equality">
          <h3>{homePage.mission.pillars[1].title}</h3>
          <p>
            {homePage.mission.pillars[1].text}
          </p>
        </div>
        <div class="pillar-card convene" style="width: 500px">
          <h3>{homePage.mission.pillars[2].title}</h3>
          <p>
            {homePage.mission.pillars[2].text}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED CONFERENCE -->
  <section class="feat-conf">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{homePage.featuredConference.eyebrow}</div>
        <h2 class="h-section">{homePage.featuredConference.heading}</h2>
        {homePage.featuredConference.sub && <p class="muted">{homePage.featuredConference.sub}</p>}
      </div>
      <div class="feat-card">
        <div class="pic" aria-hidden="true" style={`background-image:url('${homePage.featuredConference.card.img}')`}></div>
        <div class="body">
          {homePage.featuredConference.card.eyebrow && <div class="eyebrow">{homePage.featuredConference.card.eyebrow}</div>}
          <h3>{homePage.featuredConference.card.title}</h3>
          <div class="meta-stack">
            <div class="meta-row"><span class="emoji">🗓️</span> {homePage.featuredConference.card.meta}</div>
            {homePage.featuredConference.card.location && <div class="meta-row"><span class="emoji">📍</span> {homePage.featuredConference.card.location}</div>}
          </div>
          <p>
            {homePage.featuredConference.card.text}
          </p>
          {homePage.featuredConference.card.cfpNote && (
            <p class="cfp-note-card">
              {homePage.featuredConference.card.cfpNote}{' '}
              {homePage.featuredConference.card.cfpLink?.href && (
                <a class="cfp-note-link" href={homePage.featuredConference.card.cfpLink.href}>{homePage.featuredConference.card.cfpLink.label || 'Learn more'}</a>
              )}
            </p>
          )}
          <div class="ctas">
            <a class="btn btn--primary" href={homePage.featuredConference.card.cta.href}>{homePage.featuredConference.card.cta.label}</a>
            {homePage.featuredConference.card.cta2?.label && (
              <a
                class="btn btn--ghost"
                href={homePage.featuredConference.card.cta2.href}
                target={homePage.featuredConference.card.cta2.href?.startsWith('http') ? '_blank' : undefined}
                rel={homePage.featuredConference.card.cta2.href?.startsWith('http') ? 'noopener noreferrer' : undefined}
              >{homePage.featuredConference.card.cta2.label}</a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 19TH CONFERENCE HIGHLIGHTS -->
  <section class="highlights-19">
    <div class="shell">
      {homePage.highlights.eyebrow && <div class="eyebrow">{homePage.highlights.eyebrow}</div>}
      <h2>{homePage.highlights.heading}</h2>
      <div class="stage" id="highlights-stage" data-yt={homePage.highlights.youtubeId} style={`background-image:url('${homePage.highlights.img}')`} aria-label="Conference highlights video">
        <span class="caption">{homePage.highlights.caption}</span>
        <button class="play-pill" aria-label="Play highlights video"></button>
      </div>
      <a class="btn btn--ghost more" href={homePage.highlights.cta.href}>{homePage.highlights.cta.label}</a>
    </div>
  </section>

  <!-- PAST CONFERENCES -->
  <section>
    <div class="shell">
      <div class="section-head section-head--left" style="flex-direction:row; justify-content:space-between; align-items:flex-end;">
        <div style="display:flex; flex-direction:column; gap:8px;">
          <div class="eyebrow">{homePage.pastConferences.eyebrow}</div>
          <h2 class="h-section">{homePage.pastConferences.heading}</h2>
        </div>
        <a href={homePage.pastConferences.seeAll.href} class="btn btn--ghost btn--sm">{homePage.pastConferences.seeAll.label} <span class="arr">→</span></a>
      </div>
      <div class="past-row">
        {homePage.pastConferences.cards.map((c) => (
          <a class="past-card" href={c.href}>
            <div class="pic" style={`background-image:url('${c.img}');`}><span class="num">{c.num}</span></div>
            <div class="body">
              <div class="meta">{c.meta}</div>
              <h3>{c.title}</h3>
              <span class="view">{c.linkLabel}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LATEST -->
  <section>
    <div class="shell">
      <div class="section-head section-head--left" style="flex-direction:row; justify-content:space-between; align-items:flex-end;">
        <div style="display:flex; flex-direction:column; gap:8px;">
          <div class="eyebrow">{homePage.latest.eyebrow}</div>
          <h2 class="h-section">{homePage.latest.heading}</h2>
        </div>
        <a href={homePage.latest.seeAll.href} class="btn btn--ghost btn--sm">{homePage.latest.seeAll.label} <span class="arr">→</span></a>
      </div>

      <div class="latest-row">
        <article class="latest-feature">
          <div class="media" style={`background-image:url('${homePage.latest.feature.img}'); background-position: ${homePage.latest.feature.focus};`}></div>
          <div class="body">
            <div class="eyebrow">{homePage.latest.feature.eyebrow}</div>
            <h3>{homePage.latest.feature.title}</h3>
            <p>{homePage.latest.feature.text}</p>
            <a class="latest-link" href={homePage.latest.feature.href}>{homePage.latest.feature.linkLabel}</a>
          </div>
        </article>

        <div class="latest-stack">
          {homePage.latest.items.map((m) => (
            <article class="latest-mini">
              <div class="media" style={`background-image:url('${m.img}')`}></div>
              <div class="body">
                <div class="eyebrow">{m.eyebrow}</div>
                <h3>{m.title}</h3>
                {m.text && <p class="mini-sub">{m.text}</p>}
                <a class="latest-link" href={m.href}>{m.linkLabel}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PRESS -->
  <section class="press">
    <div class="shell">
      <div class="section-head">
        {homePage.press.eyebrow && <div class="eyebrow">{homePage.press.eyebrow}</div>}
        <h2 class="h-section">{homePage.press.heading}</h2>
      </div>
      <div class="press-grid">
        {homePage.press.logos.map((p) => (
          <a class="press-tile" href={p.href} target="_blank" rel="noopener noreferrer"
            ><img class="logo" src={p.img} alt={p.alt} style={`width: ${p.width}; height: ${p.height}`} loading="lazy" /></a
          >
        ))}
      </div>
    </div>
  </section>

  <!-- BRANCHES MAP -->
  <section class="branches">
    <div class="shell">
      <div class="section-head">
        {homePage.branches.eyebrow && <div class="eyebrow">{homePage.branches.eyebrow}</div>}
        <h2 class="h-section">{homePage.branches.heading}</h2>
        <p class="muted" style="max-width:62ch;">
          <Fragment set:html={homePage.branches.text} />
        </p>
      </div>
      <div class="map-wrap" id="home-map">
        <div class="map-popup" id="map-popup">
          <button class="x" type="button" aria-label="Close">✕</button>
          <div class="kind"></div>
          <h3></h3>
          <p></p>
          <div class="plinks"></div>
        </div>
      </div>
      <div style="text-align:center; margin-top:24px;">
        <a class="btn btn--white" href={homePage.branches.cta.href} style="border:1px solid var(--border);">{homePage.branches.cta.label} <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- WAYS TO SUPPORT -->
  <section class="ways">
    <div class="shell">
      <div class="section-head">
        {homePage.ways.eyebrow && <div class="eyebrow">{homePage.ways.eyebrow}</div>}
        <h2 class="h-section">{homePage.ways.heading}</h2>
      </div>
      <div class="ways-grid">
        {homePage.ways.cards.map((c, i) => (
          <a class={`way ${wayMods[i] ?? ''}`} href={c.href}>
            <div class="glyph" aria-hidden="true" style={`background-image:url('${c.img}')`}></div>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
            <span class={`btn ${i === 0 ? 'btn--primary' : 'btn--ghost'} btn--sm`} style="margin-top:6px;">{c.ctaLabel}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Map pin data -->
  <script type="application/json" id="branches-map-data" set:html={JSON.stringify(branchesMap)} />

  <script is:inline defer src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/topojson-client@3.1.0/dist/topojson-client.min.js"></script>

  <script>
    // ── 19th Conference highlights video ──
    // Phones: load the player directly so ONE tap starts the video
    // (the poster-then-play approach needs two taps on iOS).
    const stage = document.getElementById('highlights-stage')
    const directPlayer = window.matchMedia('(max-width: 760px)').matches
    function mountHighlights(autoplay: boolean) {
      if (!stage || stage.classList.contains('is-playing')) return
      stage.innerHTML = `<iframe class="hl-frame" src="https://www.youtube-nocookie.com/embed/${stage.dataset.yt}?rel=0&playsinline=1${autoplay ? '&autoplay=1' : ''}" title="Highlights of the 19th Sakyadhita Conference" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`
      stage.classList.add('is-playing')
    }
    if (directPlayer) mountHighlights(false)
    else stage?.addEventListener('click', () => mountHighlights(true))

    // ── Interactive branches world map ──
    document.addEventListener('DOMContentLoaded', () => {
      const wrap = document.getElementById('home-map')
      const popup = document.getElementById('map-popup')
      const d3 = (window as any).d3
      const topojson = (window as any).topojson
      if (!wrap || !popup || !d3 || !topojson) return

      const data = JSON.parse(document.getElementById('branches-map-data')!.textContent!)
      const KIND: Record<string, string> = data.kinds
      const SPOTS: {
        name: string
        kind: string
        lat: number
        lng: number
        desc: string
        contact?: { icon: string; text: string; url?: string }[]
      }[] = data.spots

      const W = 1000
      const H = 430
      const svg = d3
        .select(wrap)
        .insert('svg', ':first-child')
        .attr('viewBox', `0 0 ${W} ${H}`)
        .attr('role', 'img')
        .attr('aria-label', 'World map of Sakyadhita branches and chapters')

      d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2.0.2/countries-110m.json').then((topo: any) => {
        const countries = topojson.feature(topo, topo.objects.countries)
        countries.features = countries.features.filter((f: any) => f.id !== '010') // drop Antarctica
        const projection = d3.geoNaturalEarth1()
        projection.fitSize([W, H], countries)
        const path = d3.geoPath(projection)

        svg.append('g').selectAll('path').data(countries.features).join('path').attr('class', 'country').attr('d', path)

        const dots = svg
          .append('g')
          .selectAll('g')
          .data(SPOTS)
          .join('g')
          .attr('class', (d: any) => `map-dot kind-${d.kind}`)
          .attr('transform', (d: any) => {
            const p = projection([d.lng, d.lat])
            return `translate(${p[0]},${p[1]})`
          })
        dots.append('circle').attr('class', 'halo').attr('r', 10).attr('fill', 'rgba(119,59,250,.15)')
        dots.append('circle').attr('class', 'core').attr('r', 5)

        dots.on('click', (event: MouseEvent, d: any) => {
          const p = projection([d.lng, d.lat])
          const box = wrap.getBoundingClientRect()
          const x = (p[0] / W) * box.width
          const y = (p[1] / H) * box.height
          popup.querySelector('.kind')!.textContent = KIND[d.kind]
          popup.querySelector('h3')!.textContent = d.name
          popup.querySelector('p')!.textContent = d.desc
          popup.querySelector('.plinks')!.innerHTML = (d.contact || [])
            .map(
              (c: { icon: string; text: string; url?: string }) =>
                `<div>${c.icon} ${c.url ? `<a href="${c.url}">${c.text}</a>` : `<span>${c.text}</span>`}</div>`
            )
            .join('')
          popup.classList.add('is-open')
          // Keep the card fully visible inside the map panel.
          const pw = (popup as HTMLElement).offsetWidth || 260
          const ph = (popup as HTMLElement).offsetHeight || 120
          const px = Math.min(Math.max(x + 14, 8), box.width - pw - 8)
          const py = Math.min(Math.max(y - 20, 8), box.height - ph - 8)
          ;(popup as HTMLElement).style.left = `${px}px`
          ;(popup as HTMLElement).style.top = `${py}px`
          event.stopPropagation()
        })

        popup.querySelector('.x')!.addEventListener('click', () => popup.classList.remove('is-open'))
        wrap.addEventListener('click', (e) => {
          const t = e.target as Element
          if (!t.closest('.map-dot') && !t.closest('.map-popup')) popup.classList.remove('is-open')
        })
      })
    })
  </script>

  <style is:global>
    /* Home-only — noise texture overlay above the orb gradients gives
       the cream surface a paper-grain feel. */
    .page-bg::after {
      content: "";
      position: absolute; inset: 0;
      background: url('/assets/noise-bg.png') repeat;
      background-size: 480px 480px;
      mix-blend-mode: multiply;
      opacity: .55;
      pointer-events: none;
    }

    .home-hero {
      position: relative;
      margin: 0;
      padding: 36px 32px 0;
      overflow: hidden;
      text-align: center;
    }
    .home-hero .content {
      position: relative;
      max-width: 820px;
      margin: 0 auto;
      display: flex; flex-direction: column; align-items: center;
    }
    .home-hero .hero-logo {
      width: 96px; height: 96px;
      object-fit: contain;
      margin-bottom: 20px;
    }
    .home-hero h1 {
      font-family: var(--font-title);
      font-weight: 700;
      line-height: 1.1;
      color: var(--ink);
      margin: 0 0 12px;
    }
    .home-hero h1 .name { display: block; font-size: 40px; margin-bottom: 2px; }
    .home-hero h1 .full { display: block; font-size: 40px; letter-spacing: -0.01em; white-space: nowrap; }
    .latest-mini .mini-sub { font-size: 13px; line-height: 1.45; color: var(--ink-body); margin: 1px 0; }
    .home-hero .eyebrow.hero-announce { color: var(--coral-2); margin: 2px 0 10px; line-height: 1.5; }
    .cfp-note-card {
      font-size: 14.5px; line-height: 1.6; color: var(--ink-body);
      margin-top: 2px;
      padding: 14px 16px;
      background: var(--bg-warm);
      border-radius: var(--r-md);
    }
    .cfp-note-link { color: var(--purple); font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
    .cfp-note-link:hover { color: var(--ink); }
    .home-hero p {
      color: var(--ink-body);
      font-size: 18px;
      max-width: 900px;
      line-height: 1.6;
      margin: 0 auto 24px;
    }
    .home-hero .cta-row { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }

    /* Infinite image marquee */
    .hero-marquee {
      margin-top: 36px;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      width: 100vw;
      overflow: hidden;
    }
    .home-hero .marquee-credit {
      margin-top: 24px;
      text-align: center;
      font-size: 16px;
      color: #888888;
      padding-top: 8px;
      padding-bottom: 8px;
    }
    .home-hero .marquee-credit a {
      color: #888888;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .hero-marquee .track a { display: contents; }
    .hero-marquee .track {
      display: flex;
      gap: 24px;
      width: max-content;
      animation: heroScroll 60s linear infinite;
    }
    .hero-marquee .track img {
      width: 360px;
      height: 440px;
      object-fit: cover;
      border-radius: var(--r-lg);
      flex: none;
    }
    @keyframes heroScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-marquee .track a { display: contents; }
    .hero-marquee .track { animation: none; }
    }
    @media (max-width: 1024px) {
      .home-hero h1 .full { font-size: clamp(28px, 4.6vw, 40px); }
    }
    @media (max-width: 720px) {
      .home-hero h1 .name { font-size: 30px; }
      .home-hero h1 .full { font-size: 28px; white-space: normal; }
      .home-hero p { font-size: 16px; }
      .hero-marquee .track a { display: contents; }
    .hero-marquee .track { gap: 16px; }
      .hero-marquee .track img { width: 240px; height: 300px; }
    }
    @media (max-width: 640px) {
      .home-hero { padding-left: 16px; padding-right: 16px; }
    }

    /* Mission with central mandala */
    .mission-alt {
      position: relative;
      padding: 32px 0 80px;
    }
    .mission-alt .intro {
      max-width: 70ch;
      margin: 0 auto 20px;
      text-align: center;
    }
    .mission-alt .intro p {
      font-size: 16px;
      line-height: 1.7;
      color: var(--ink-body);
      margin-top: 16px;
    }
    .mission-alt .layout {
      display: grid;
      grid-template-columns: 1fr minmax(280px, 360px) 1fr;
      grid-template-areas:
        "connect mandala equality"
        "convene convene convene";
      gap: 28px;
      align-items: center;
      justify-items: center;
    }
    .mission-alt .layout > * { min-width: 0; }
    .mission-alt .mandala {
      grid-area: mandala;
      width: 100%;
      max-width: 320px;
      aspect-ratio: 1/1;
      background: url('/assets/mission-mandala.svg') center/contain no-repeat;
    }
    .mission-alt .pillar-card { width: 100%; max-width: min(460px, 100%); min-width: 0; box-sizing: border-box; }
    .mission-alt .pillar-card.connect  { grid-area: connect; }
    .mission-alt .pillar-card.equality { grid-area: equality; }
    .mission-alt .pillar-card.convene  { grid-area: convene; max-width: min(720px, 100%); }
    .mission-alt .pillar-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 28px 32px;
      display: flex; flex-direction: column;
      gap: 12px;
      text-align: center;
      transition: transform .15s, box-shadow .2s, border-color .15s;
    }
