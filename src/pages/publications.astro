---
/**
 * Publications library — bibliographies, books, conference brochures,
 * membership brochures in 9 languages, and translated scholarship.
 *
 * PDF links currently point at the old site's files; they will move to
 * stable paths on this site during content migration.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Publications · Sakyadhita"
  description="Bibliographies, books, conference brochures, and translations on Buddhist women's lives, history, and scholarship — gathered over four decades by Sakyadhita. Free and open to all."
  active="resources"
  ogImage="/assets/publication.png"
>
  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">RESOURCES · PUBLICATIONS</div>
      <h1 class="h-display">A scholarly library of Buddhist women's lives and words</h1>
      <p class="lede">
        Bibliographies, books, conference brochures, and translations gathered over four decades —
        documenting the history, texts, and stories of Buddhist women across traditions. Free and
        open to all.
      </p>
    </div>
  </section>

  <!-- BIBLIOGRAPHIES -->
  <section id="bibliographies">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">BIBLIOGRAPHIES</div>
        <h2 class="h-section">Five reading lists on Buddhist women</h2>
      </div>
      <div class="book-grid">
        <a class="book" href="https://sakyadhita.org/_astro/04a%20Bibliographies%20Historical.CsfjfmWO.pdf" target="_blank" rel="noopener noreferrer">
          <div class="cover photo" style="background-image:url('/assets/bib-historical.jpg')"><span class="b-kind">HISTORICAL</span><span class="b-title">Tracing the Histories of Buddhist Women</span></div>
          <div class="foot"><span class="src">Sakyadhita</span><span class="lnk">PDF →</span></div>
        </a>
        <a class="book" href="https://sakyadhita.org/_astro/04b%20Bibliographies%20Textual.BdG7lsOM.pdf" target="_blank" rel="noopener noreferrer">
          <div class="cover photo" style="background-image:url('/assets/bib-textual.jpg')"><span class="b-kind">TEXTUAL STUDIES</span><span class="b-title">Texts Documenting Buddhist Women</span></div>
          <div class="foot"><span class="src">Sakyadhita</span><span class="lnk">PDF →</span></div>
        </a>
        <a class="book" href="https://sakyadhita.org/_astro/04c%20Bibliographies%20Profiles%20Interviews.P_Ue7r36.pdf" target="_blank" rel="noopener noreferrer">
          <div class="cover photo" style="background-image:url('/assets/bib-profiles.jpg')"><span class="b-kind">BIOGRAPHIES &amp; PROFILES</span><span class="b-title">Recounting the Stories of Buddhist Women</span></div>
          <div class="foot"><span class="src">Sakyadhita</span><span class="lnk">PDF →</span></div>
        </a>
        <a class="book" href="https://sakyadhita.org/_astro/04d%20Bibliographies%20Contemporary.CppzMjnx.pdf" target="_blank" rel="noopener noreferrer">
          <div class="cover photo" style="background-image:url('/assets/bib-contemporary.jpg')"><span class="b-kind">CONTEMPORARY STUDIES</span><span class="b-title">Researching the Lives of Buddhist Women</span></div>
          <div class="foot"><span class="src">Sakyadhita</span><span class="lnk">PDF →</span></div>
        </a>
        <a class="book" href="https://sakyadhita.org/_astro/04e%20General%20and%20Miscellaneous.B5QfkFni.pdf" target="_blank" rel="noopener noreferrer">
          <div class="cover photo" style="background-image:url('/assets/bib-general.jpg')"><span class="b-kind">GENERAL &amp; MISC.</span><span class="b-title">More about Buddhist Women</span></div>
          <div class="foot"><span class="src">Sakyadhita</span><span class="lnk">PDF →</span></div>
        </a>
      </div>
    </div>
  </section>

