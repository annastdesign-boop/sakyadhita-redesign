---
/**
 * Donate page — impact amounts, the PayPal donate button, and
 * more-ways-to-support cards.
 *
 * The button uses Sakyadhita's real PayPal hosted donate button
 * (the design linked to PayPal's generic page by mistake).
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import donatePage from '../data/pages/donate.json'

const PAYPAL_DONATE_URL = donatePage.paypalUrl
---

<BaseLayout
  title={donatePage.seo.title}
  description={donatePage.seo.description}
  active="get-involved"
  ogImage={donatePage.seo.ogImage}
>
  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">{donatePage.hero.eyebrow}</div>
      <h1 class="h-display">{donatePage.hero.title}</h1>
      <p class="lede">{donatePage.hero.lede}</p>
    </div>
  </section>

  <section>
    <div class="shell">
      <div class="section-head" style="text-align: center;">
        <div class="eyebrow">{donatePage.impact.eyebrow}</div>
        <h2 class="h-section">{donatePage.impact.heading}</h2>
        <p class="lede" style="max-width: 640px; margin: 14px auto 0;">{donatePage.impact.lede}</p>
      </div>
      <div class="impact-amounts">
        {
          donatePage.impact.cards.map((card) => (
            <div class="impact-amt">
              <div class="v">{card.value}</div>
              <p>{card.text}</p>
            </div>
          ))
        }
      </div>
      <div class="impact-cta">
        <a class="btn btn--primary btn--lg" href={PAYPAL_DONATE_URL} target="_blank" rel="noopener noreferrer">
          {donatePage.donateButtonLabel} <span class="arr">→</span>
        </a>
      </div>
      <div class="tax-card" style="max-width: 640px; margin: 28px auto 0;">
        <span style="font-size: 24px;">🧾</span>
        <div>
          <b>{donatePage.taxNote.lead}</b> {donatePage.taxNote.text}
        </div>
      </div>
    </div>
  </section>

  <section class="ways">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{donatePage.ways.eyebrow}</div>
        <h2 class="h-section">{donatePage.ways.heading}</h2>
      </div>
      <div class="ways-grid">
        {
          donatePage.ways.cards.map((card, i) => (
            <a class="way" href={card.href}>
              <div class="glyph" aria-hidden="true" style={`background-image: url('${card.img}');`}></div>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <span class={i === 0 ? 'btn btn--primary btn--sm' : 'btn btn--ghost btn--sm'} style="margin-top:6px;">{card.buttonLabel}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <style is:global>
    .impact-amounts {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 8px;
    }
    .impact-amt {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 28px 24px;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }
    .impact-amt .v {
      font-family: var(--font-num);
      font-weight: 700;
      font-size: 40px;
      color: var(--purple);
      line-height: 1;
    }
    .impact-amt p {
      font-size: 14.5px;
      color: var(--ink-body);
      line-height: 1.5;
      margin: 0;
    }
    .impact-cta {
      margin-top: 40px;
      text-align: center;
    }
    @media (max-width: 900px) {
      .impact-amounts { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .impact-amounts { grid-template-columns: 1fr; }
    }

    .tax-card {
      margin-top: 18px;
      padding: 16px 18px;
      background: var(--bg-subtle);
      border-radius: var(--r-md);
      font-size: 13.5px;
      color: var(--ink-2);
      display: flex; gap: 12px;
    }
    .tax-card b { color: var(--ink); }

    .site-footer { margin-top: 0; }

    .ways { padding: 0 0 112px; }
    .ways-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; max-width: 760px; margin: 0 auto; }
    .way {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 40px 32px 32px;
      text-align: center;
      display: flex; flex-direction: column; gap: 14px;
      align-items: center;
      text-decoration: none; color: inherit;
      transition: transform .15s, box-shadow .2s;
    }
    .way:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .way .glyph {
      width: 168px; height: 168px;
      background-size: contain; background-position: center; background-repeat: no-repeat;
    }
    .way h3 { font-family: var(--font-title); font-weight: 700; font-size: 26px; color: var(--ink); }
    .way p { font-size: 14.5px; color: var(--ink-body); line-height: 1.55; padding: 0 16px; }
    @media (max-width: 640px) {
      .ways-grid { grid-template-columns: 1fr; }
      .way { padding: 32px 24px 28px; }
      /* Bigger, full-width buttons inside the support cards */
      .way .btn {
        width: 100%;
        justify-content: center;
        padding: 16px;
        font-size: 15px;
      }
    }
  </style>
</BaseLayout>
