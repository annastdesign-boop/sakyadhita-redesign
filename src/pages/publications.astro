        </a>
        <a class="book" href="https://www.amazon.com/Sakyadhita-Daughters-Karma-Lekshe-Tsomo/dp/0937938726/" target="_blank" rel="noopener noreferrer">
          <div class="cover grad bk5"><span class="b-title">Sakyadhita: Daughters of the Buddha</span><span class="b-auth">Karma Lekshe Tsomo</span></div>
          <div class="foot"><span class="src">Snow Lion</span><span class="lnk">View →</span></div>
        </a>
      </div>
    </div>
  </section>

