---
/**
 * Contact page — routing cards, the general-inquiry form (a real
 * Netlify Form named "contact"), direct contact details, and social.
 *
 * Submissions appear in Netlify → Forms → "contact".
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import contactPage from '../data/pages/contact.json'
---

<BaseLayout
  title={contactPage.seo.title}
  description={contactPage.seo.description}
  active="contact"
>
  <div class="shell">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a><span class="sep">›</span><span>Contact</span>
    </nav>
  </div>

  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">{contactPage.hero.eyebrow}</div>
      <h1 class="h-display">{contactPage.hero.title}</h1>
      <p class="lede">{contactPage.hero.lede}</p>
    </div>
  </section>

  <section>
    <div class="shell">
      <div class="section-head section-head--left">
        <div class="eyebrow">{contactPage.routing.eyebrow}</div>
        <h2 class="h-section" style="margin-top: 8px;">{contactPage.routing.heading}</h2>
        <p class="muted" style="margin-top: 6px;">{contactPage.routing.sub}</p>
      </div>
      <div class="routes">
        {
          contactPage.routing.cards.map((card) => (
            <a class="route" href={card.href} id={card.id || undefined}>
              <div class="ico" style={card.iconBg ? `background: ${card.iconBg};` : undefined}>{card.icon}</div>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <span class="cta">{card.cta}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section--bg-subtle" id="form">
    <div class="shell">
      <div class="form-grid">
        <form
          class="form-card"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <input type="hidden" name="form-name" value="contact" />
          <p hidden aria-hidden="true">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <div class="eyebrow">{contactPage.form.eyebrow}</div>
          <h2>{contactPage.form.heading}</h2>
          <div class="stack-4">
            <div class="form-row">
              <div class="field">
                <label for="c-name">Name *</label>
                <input id="c-name" name="name" type="text" required autocomplete="name" />
              </div>
              <div class="field">
                <label for="c-email">Email *</label>
                <input id="c-email" name="email" type="email" required placeholder="you@email.com" autocomplete="email" />
              </div>
            </div>
            <div class="field">
              <label for="c-subject">Subject *</label>
              <input id="c-subject" name="subject" type="text" required />
            </div>
            <div class="field">
              <label for="c-topic">Topic</label>
              <select id="c-topic" name="topic">
                <option>General</option>
                <option>Membership</option>
                <option>Conference</option>
                <option>Donation</option>
                <option>Resources</option>
                <option>Ordination</option>
                <option>Branch / Chapter</option>
                <option>Press</option>
                <option>Other</option>
              </select>
            </div>
            <div class="field">
              <label for="c-message">Message *</label>
              <textarea id="c-message" name="message" required placeholder="Tell us what you'd like to discuss…"></textarea>
            </div>
          </div>
          <div class="submit-wrap" style="margin-top: 24px; display: flex; justify-content: flex-end;">
            <button type="submit" class="btn btn--primary btn--lg">{contactPage.form.submitLabel} <span class="arr">→</span></button>
          </div>
        </form>

        <div>
          <div class="eyebrow" style="margin-bottom: 8px;">{contactPage.direct.eyebrow}</div>
          <h2 class="h-section" style="margin-bottom: 22px;">{contactPage.direct.heading}</h2>
          <div class="contact-info">
            {
              contactPage.direct.blocks.map((block) => (
                <div class:list={['info-block', block.callout && 'callout']}>
                  <div class="ico" style={block.iconBg ? `background: ${block.iconBg};` : undefined}>{block.icon}</div>
                  <div>
                    <div class="l">{block.label}</div>
                    {block.href ? <a class="v" href={block.href}>{block.value}</a> : <div class="v">{block.value}</div>}
                    {block.note && <div class="m">{block.note}</div>}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="social">
    <div class="shell">
      <div class="eyebrow">{contactPage.social.eyebrow}</div>
      <h2 class="h-section" style="margin-top: 12px;">{contactPage.social.heading}</h2>
      <div class="social-row">
        <a href="https://www.facebook.com/sakyadhita.international" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3l.4-3H14V4.2c0-.85.25-1.45 1.5-1.45H17V.1C16.7.05 15.8 0 14.7 0 12.4 0 10.8 1.4 10.8 4v2H8v3h2.8v8H14V9z"/></svg></a>
        <a href="https://www.youtube.com/@sakyadhitainternational" target="_blank" rel="noopener noreferrer" title="YouTube" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.5a3 3 0 0 0-2.1-2.1C19.5 4 12 4 12 4s-7.5 0-9.4.4A3 3 0 0 0 .5 6.5C.1 8.4.1 12 .1 12s0 3.6.4 5.5a3 3 0 0 0 2.1 2.1C4.5 20 12 20 12 20s7.5 0 9.4-.4a3 3 0 0 0 2.1-2.1c.4-1.9.4-5.5.4-5.5s0-3.6-.4-5.5zM9.6 15.5v-7l6.3 3.5-6.3 3.5z"/></svg></a>
        <a href="https://www.pinterest.com/sakyadhita/" target="_blank" rel="noopener noreferrer" title="Pinterest" aria-label="Pinterest"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12c0 5 3.1 9.3 7.5 11-.1-.9-.2-2.4 0-3.4l1.4-5.9s-.4-.7-.4-1.8c0-1.6.95-2.8 2.1-2.8 1 0 1.5.75 1.5 1.65 0 1-.65 2.5-.95 3.9-.3 1.15.6 2.1 1.7 2.1 2 0 3.6-2.15 3.6-5.2 0-2.7-1.95-4.6-4.7-4.6-3.2 0-5.1 2.4-5.1 4.9 0 .95.35 2 .85 2.55.1.1.1.2.1.3l-.3 1.3c0 .2-.15.3-.35.15-1.3-.6-2.1-2.5-2.1-4 0-3.3 2.4-6.3 6.9-6.3 3.6 0 6.4 2.6 6.4 6 0 3.6-2.25 6.5-5.4 6.5-1.05 0-2.05-.55-2.4-1.2l-.65 2.5c-.25.9-.9 2.05-1.3 2.75 1 .3 2.05.45 3.15.45 6.6 0 12-5.4 12-12S18.6 0 12 0z"/></svg></a>
        <a href="https://awakeningbuddhistwomen.blogspot.com/" target="_blank" rel="noopener noreferrer" title="Blog" aria-label="Blog"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.976 24H2.026C.9 24 0 23.1 0 21.976V2.026C0 .9.9 0 2.026 0h19.95C23.1 0 24 .9 24 2.026v19.95C24 23.1 23.1 24 21.976 24zM12.154 5.5H9.5C7.29 5.5 5.5 7.29 5.5 9.5v5c0 2.21 1.79 4 4 4h5c2.21 0 4-1.79 4-4v-2.846c0-.637-.517-1.154-1.154-1.154h-.847c-.581 0-1.06-.435-1.135-1.008C15.096 6.633 13.803 5.5 12.154 5.5zM9.6 8.5h2c.552 0 1 .448 1 1s-.448 1-1 1h-2c-.552 0-1-.448-1-1s.448-1 1-1zm4.8 7H9.6c-.552 0-1-.448-1-1s.448-1 1-1h4.8c.552 0 1 .448 1 1s-.448 1-1 1z"/></svg></a>
        <a href="https://www.goodreads.com/group/show/94269-women-in-buddhism" target="_blank" rel="noopener noreferrer" title="Goodreads" aria-label="Goodreads"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.43 23.995c-3.608-.208-6.274-2.077-6.448-5.078.695.007 1.416-.013 2.078.006.224 1.6 1.626 2.792 3.583 3.107 2.634.415 5.652-.297 6.098-3.983.264-2.184.03-3.183.03-4.196v-.35c-.941 2.29-2.746 3.583-5.28 3.583C7.256 17.077 4.5 13.7 4.5 9.75 4.5 5.752 7.36 2.42 11.62 2.42c2.634 0 4.196 1.334 5.15 3.35V2.72h1.977v13.834c0 4.802-2.516 7.19-7.31 7.44zm.204-19.622c-3.325 0-5.15 2.72-5.15 5.436 0 2.912 1.66 5.494 5.05 5.494 3.42 0 5.15-2.71 5.15-5.494 0-2.912-1.66-5.436-5.05-5.436z"/></svg></a>
      </div>
    </div>
  </section>

  <script type="application/json" id="contact-copy" set:html={JSON.stringify(contactPage.success)} />
  <script>
    import { enhanceForm } from '../scripts/forms'
    const copy = JSON.parse(document.getElementById('contact-copy')?.textContent || '{}')
    enhanceForm(document.querySelector('form[name="contact"]'), {
      successTitle: copy.title || 'Message sent',
      successText: copy.text || '',
    })
  </script>

  <style is:global>
    .routes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .route {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 32px 28px;
      display: flex; flex-direction: column; gap: 12px;
      transition: transform .15s, border-color .15s, box-shadow .15s;
      text-decoration: none; color: inherit;
    }
    .route:hover { transform: translateY(-2px); border-color: var(--lavender-2); box-shadow: var(--shadow-md); }
    .route .ico {
      width: 52px; height: 52px;
      border-radius: 50%;
      background: var(--lavender);
      display: grid; place-items: center;
      font-size: 24px;
    }
    .route h3 { font-family: var(--font-title); font-weight: 700; font-size: 24px; color: var(--ink); }
    .route p { font-size: 14.5px; color: var(--ink-body); line-height: 1.55; }
    .route .cta { color: var(--purple); font-weight: 600; font-size: 14px; margin-top: auto; }

    .form-grid {
      display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px;
      align-items: start;
    }
    .form-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 36px;
      box-shadow: var(--shadow-md);
    }
    .form-card h2 { font-family: var(--font-title); font-weight: 700; font-size: 32px; color: var(--ink); margin: 8px 0 22px; }
    .form-card .stack-4 { display: flex; flex-direction: column; gap: 16px; }
    .form-card .field { gap: 4px; }

    .contact-info { display: flex; flex-direction: column; gap: 14px; }
    .info-block {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 22px;
      display: grid;
      grid-template-columns: 44px 1fr;
      gap: 14px;
      align-items: start;
    }
    .info-block .ico {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--lavender);
      display: grid; place-items: center;
      font-size: 20px;
    }
    .info-block .l { font-size: 11.5px; font-weight: 700; letter-spacing: 0.14em; color: var(--ink-subtle); text-transform: uppercase; margin-bottom: 4px; }
    .info-block .v { font-size: 15.5px; color: var(--ink); font-weight: 600; word-break: break-word; }
    .info-block .m { font-size: 13px; color: var(--ink-2); margin-top: 4px; line-height: 1.4; }
    .info-block.callout {
      background: var(--bg-subtle);
      border-style: dashed;
    }
    .info-block.callout .v { font-weight: 500; font-size: 14.5px; line-height: 1.5; }

    .social {
      padding: 80px 0;
      text-align: center;
    }
    .site-footer { margin-top: 0; }
    .social-row {
      display: flex; gap: 14px; justify-content: center; margin-top: 24px;
    }
    .social-row a {
      width: 52px; height: 52px;
      border-radius: 50%;
      background: #fff;
      border: 1px solid var(--border);
      display: grid; place-items: center;
      font-weight: 700; color: var(--ink); font-size: 14px;
      transition: background .12s, transform .15s, color .12s;
    }
    .social-row a:hover { background: var(--ink); color: #fff; transform: translateY(-2px); }
    .social-row a svg { width: 22px; height: 22px; }

    @media (max-width: 900px) {
      .routes { grid-template-columns: 1fr; }
      .form-grid { grid-template-columns: 1fr; gap: 28px; }
    }
    @media (max-width: 560px) {
      .form-row { grid-template-columns: 1fr; }
      .submit-wrap { justify-content: stretch; }
      .submit-wrap .btn { width: 100%; justify-content: center; }
      /* Wider fields on phones — 8px from the card border */
      .form-card { padding: 28px 8px; }
    }
  </style>
</BaseLayout>
