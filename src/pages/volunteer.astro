---
/**
 * Volunteer page — committees overview, the application form (a real
 * Netlify Form named "volunteer"), and Q&A accordion.
 *
 * Submissions appear in Netlify → Forms → "volunteer".
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import volunteerPage from '../data/pages/volunteer.json'

const committees = volunteerPage.interests
---

<BaseLayout
  title={volunteerPage.seo.title}
  description={volunteerPage.seo.description}
  active="get-involved"
  ogImage={volunteerPage.seo.ogImage}
>
  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">{volunteerPage.hero.eyebrow}</div>
      <h1 class="h-display">{volunteerPage.hero.title}</h1>
      <p class="lede">{volunteerPage.hero.lede}</p>
      <div class="cta-row" style="margin-top: 28px;">
        <a class="btn btn--primary btn--lg" href="#apply">{volunteerPage.hero.buttonLabel} <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <section class="committees">
    <div class="shell">
      <div class="com-split">
        <div class="com-left">
          <div class="section-head section-head--left">
            <div class="eyebrow">{volunteerPage.committees.eyebrow}</div>
            <h2 class="h-section">{volunteerPage.committees.heading}</h2>
            <p class="muted">{volunteerPage.committees.text}</p>
            <a class="btn btn--primary" style="margin-top: 22px;" href="#apply">{volunteerPage.committees.buttonLabel} <span class="arr">→</span></a>
          </div>
        </div>
        <div class="com-right">
          {
            volunteerPage.committees.groups.map((group) => (
              <div class="com-group">
                <div class="com-group-head">{group.heading}</div>
                <div class="com-grid">
                  {group.items.map((item) => (
                    <div class="com"><div class="com-emoji">{item.emoji}</div><div class="com-body"><h3>{item.title}</h3><p>{item.text}</p></div></div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="vol-form" id="apply">
    <div class="shell">
      <div class="section-head" style="text-align: center; margin-bottom: 34px;">
        <div class="eyebrow">{volunteerPage.formHead.eyebrow}</div>
        <h2 class="h-section">{volunteerPage.formHead.heading}</h2>
        <p class="muted" style="max-width: 620px; margin: 12px auto 0;">{volunteerPage.formHead.text}</p>
      </div>

      <form class="vform" name="volunteer" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
        <input type="hidden" name="form-name" value="volunteer" />
        <p hidden aria-hidden="true">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>

        <fieldset class="fs">
          <div class="fs-title">Your name</div>
          <div class="stack">
            <div class="form-row">
              <div class="field"><label for="v-fname">First name *</label><input id="v-fname" name="fName" type="text" required placeholder="First name" autocomplete="given-name" /></div>
              <div class="field"><label for="v-lname">Last name *</label><input id="v-lname" name="lName" type="text" required placeholder="Last name" autocomplete="family-name" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="fs">
          <div class="fs-title">Contact information</div>
          <div class="stack">
            <div class="form-row">
              <div class="field"><label for="v-email">Email address *</label><input id="v-email" name="email" type="email" required placeholder="you@email.com" autocomplete="email" /></div>
              <div class="field"><label for="v-phone">Phone (optional)</label><input id="v-phone" name="phone" type="tel" placeholder="+1 234 567 8900" autocomplete="tel" /></div>
            </div>
            <div class="field"><label for="v-address">Full address *</label><input id="v-address" name="address" type="text" required placeholder="Street, city, state/province, postal code, country" autocomplete="street-address" /></div>
            <div class="form-row">
              <div class="field">
                <label for="v-country">Country *</label>
                <select id="v-country" name="country" required>
                  <option value="">Select country</option>
                  <option>Australia</option><option>Brazil</option><option>Canada</option>
                  <option>France</option><option>Germany</option><option>India</option>
                  <option>Indonesia</option><option>Japan</option><option>Korea, Republic of</option>
                  <option>Malaysia</option><option>Mongolia</option><option>Nepal</option>
                  <option>Sri Lanka</option><option>Taiwan</option><option>Thailand</option>
                  <option>United Kingdom</option><option>United States</option>
                  <option>Vietnam</option><option>Other</option>
                </select>
              </div>
              <div class="field"><label for="v-city">City *</label><input id="v-city" name="city" type="text" required placeholder="City" autocomplete="address-level2" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="fs">
          <div class="fs-title">Committee interests</div>
          <div class="fs-sub">Select any and all committees you're interested in joining.</div>
          <div class="com-picks">
            {
              committees.map((c) => (
                <label class="com-pick">
                  <input type="checkbox" name="interests" value={c} />
                  <span class="cp-name">{c}</span>
                </label>
              ))
            }
          </div>
        </fieldset>

        <fieldset class="fs">
          <div class="fs-title">Tell us about yourself</div>
          <div class="fs-sub">Optional — share your background, skills, availability, or why you'd like to volunteer.</div>
          <div class="field"><label for="v-about" class="sr-only" style="position:absolute; left:-9999px;">About yourself</label><textarea id="v-about" name="about" placeholder="A few words about yourself…"></textarea></div>
        </fieldset>

        <div class="submit-row">
          <button type="submit" class="btn btn--primary btn--lg">{volunteerPage.formHead.submitLabel} <span class="arr">→</span></button>
          <div class="req-note">* indicates a required field</div>
        </div>
      </form>
    </div>
  </section>

  <section class="faq" id="faq">
    <div class="shell">
      <div class="faq-split">
        <div class="faq-pic" role="img" aria-label="Buddhist women in meditation at a Sakyadhita conference"></div>
        <div>
          <div class="section-head section-head--left" style="margin-bottom: 28px;">
            <div class="eyebrow">{volunteerPage.faq.eyebrow}</div>
            <h2 class="h-section">{volunteerPage.faq.heading}</h2>
          </div>
          <div class="faq-list">
            {
              volunteerPage.faq.items.map((item) => (
                <div class="faq-item">
                  <button class="faq-q" type="button">{item.question}<svg class="chev" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                  <div class="faq-a"><div class="faq-a-inner">{item.answer}</div></div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/json" id="volunteer-copy" set:html={JSON.stringify(volunteerPage.success)} />
  <script>
    import { enhanceForm } from '../scripts/forms'
    const copy = JSON.parse(document.getElementById('volunteer-copy')?.textContent || '{}')
    enhanceForm(document.querySelector('form[name="volunteer"]'), {
      successTitle: copy.title || 'Application received',
      successText: copy.text || '',
    })

    // FAQ accordion
    document.querySelectorAll('.faq-item .faq-q').forEach((q) => {
      q.addEventListener('click', () => {
        const item = q.closest('.faq-item')!
        const ans = item.querySelector('.faq-a') as HTMLElement
        const isOpen = item.classList.contains('is-open')
        if (isOpen) {
          item.classList.remove('is-open')
          ans.style.maxHeight = ''
        } else {
          item.classList.add('is-open')
          ans.style.maxHeight = `${ans.scrollHeight}px`
        }
      })
    })
  </script>

  <style is:global>
    .committees { padding: 80px 0; }
    .com-split {
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 64px;
      align-items: start;
    }
    .com-left { position: sticky; top: calc(120px + var(--announce-h, 0px)); padding: 24px 0; }
    .com-group + .com-group { margin-top: 40px; }
    .com-group-head {
      font-size: 12px; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--purple);
      padding-bottom: 12px; margin-bottom: 18px;
      border-bottom: 1px solid var(--border);
    }
    .com-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    @media (max-width: 900px) {
      .com-split { grid-template-columns: 1fr; gap: 32px; }
      .com-left { position: static; }
    }
    @media (max-width: 560px) {
      .com-grid { grid-template-columns: 1fr; }
    }
    .com {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 22px;
      display: flex; flex-direction: row; align-items: center; gap: 16px;
      transition: transform .15s, border-color .15s;
    }
    .com .com-emoji { font-size: 30px; line-height: 1; flex: none; }
    .com .com-body { display: flex; flex-direction: column; gap: 6px; }
    .com:hover { transform: translateY(-2px); border-color: var(--lavender-2); }
    .com h3 { font-family: var(--font-title); font-weight: 700; font-size: 20px; color: var(--ink); }
    .com p { font-size: 14px; color: var(--ink-body); line-height: 1.5; }

    .vol-form { padding: 80px 0; }
    #apply { scroll-margin-top: 90px; }

    .vform {
      max-width: 820px; margin: 0 auto;
      background: #fff; border: 1px solid var(--border);
      border-radius: var(--r-lg); padding: 40px 44px;
      box-shadow: var(--shadow-md);
    }
    .vform .fs { border: 0; padding: 0; margin: 0; }
    .vform .fs + .fs { margin-top: 30px; padding-top: 30px; border-top: 1px solid var(--border-soft); }
    .vform .fs-title {
      font-family: var(--font-title); font-weight: 700;
      font-size: 20px; color: var(--ink); margin-bottom: 4px;
    }
    .vform .fs-sub { font-size: 14px; color: var(--ink-2); margin-bottom: 18px; }
    .vform .stack { display: flex; flex-direction: column; gap: 16px; }
    .vform .field { gap: 4px; }
    .com-picks {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
    }
    .com-pick {
      display: flex; align-items: flex-start; gap: 10px;
      border: 1px solid var(--border); border-radius: var(--r-md);
      padding: 12px 14px; cursor: pointer;
      transition: border-color .15s, background .15s;
    }
    .com-pick:hover { border-color: var(--lavender-2); background: var(--bg-subtle); }
    .com-pick:has(input:checked) { border-color: var(--purple); background: rgba(119,59,250,.05); }
    .com-pick input { margin-top: 1px; accent-color: var(--purple); flex: none; width: 20px; height: 20px; }
    .com-pick .cp-name { font-size: 14.5px; font-weight: 600; color: var(--ink); }
    @media (max-width: 560px) {
      .com-pick { padding: 14px 16px; gap: 12px; }
      .com-pick input { width: 22px; height: 22px; }
    }
    .vform .submit-row {
      margin-top: 30px; padding-top: 26px;
      border-top: 1px solid var(--border-soft);
    }
    .vform .submit-row .btn { width: 100%; justify-content: center; }
    .vform .req-note { font-size: 12.5px; color: var(--ink-subtle); margin-top: 12px; text-align: center; }
    @media (max-width: 860px) {
      .com-picks { grid-template-columns: repeat(2, 1fr); }
      .vform { padding: 32px 24px; }
    }
    @media (max-width: 560px) {
      /* Wider fields on phones — 8px from the card border */
      .vform { padding: 28px 8px; }
    }
    @media (max-width: 520px) {
      .com-picks { grid-template-columns: 1fr; }
    }

    /* Q&A accordion */
    .faq { padding: 80px 0; }
    #faq.faq { scroll-margin-top: 90px; }
    .faq-split {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 64px;
      align-items: start;
    }
    .faq-pic {
      position: sticky; top: calc(120px + var(--announce-h, 0px));
      border-radius: var(--r-lg);
      overflow: hidden;
      aspect-ratio: 9/10;
      background: url('/assets/member-voice.png') 60% 50%/cover no-repeat;
      border: 1px solid var(--border);
    }
    @media (max-width: 900px) {
      .faq-split { grid-template-columns: 1fr; gap: 32px; }
      .faq-pic { position: static; aspect-ratio: 16/10; }
    }
    .faq-list { display: flex; flex-direction: column; gap: 12px; }
    .faq-item {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      overflow: hidden;
    }
    .faq-q {
      width: 100%;
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 20px 24px;
      background: none; border: 0; cursor: pointer;
      font: inherit; text-align: left;
      font-family: var(--font-title); font-weight: 700; font-size: 18px; color: var(--ink);
    }
    .faq-q .chev {
      flex: none; width: 22px; height: 22px; color: var(--purple);
      transition: transform .25s ease;
    }
    .faq-item.is-open .faq-q .chev { transform: rotate(180deg); }
    .faq-a {
      max-height: 0; overflow: hidden;
      transition: max-height .3s ease;
    }
    .faq-a-inner { padding: 0 24px 22px; font-size: 15px; line-height: 1.65; color: var(--ink-body); }
  </style>
</BaseLayout>
