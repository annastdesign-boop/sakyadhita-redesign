---
/**
 * BaseLayout — the shared shell every page sits inside.
 * Gives each page: fonts, SEO tags, the site header, the soft
 * "orb" background, and the footer.
 *
 * Usage:
 *   <BaseLayout title="About · Sakyadhita" description="..." active="about">
 *     ...page content...
 *   </BaseLayout>
 */
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  /** Browser-tab + search-result title */
  title: string
  /** One-sentence page summary for search engines and link previews */
  description: string
  /** Which top-nav item to highlight: home | conferences | resources | about | branches | get-involved | contact */
  active?: string
  /** Image used in social-media link previews (path under /assets) */
  ogImage?: string
}

const { title, description, active = '', ogImage = '/assets/founders-1987-bodhgaya.png' } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/assets/logo-mark.png" type="image/png" />
    <meta name="theme-color" content="#FDF9F6" />

    <!-- Social link previews (Open Graph + Twitter) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sakyadhita International Association of Buddhist Women" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Brand fonts -->
    <link rel="stylesheet" href="https://use.typekit.net/spu1aeb.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=League+Spartan:wght@400;500;600;700&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <Header active={active} />

    <main id="main">
      <!-- Decorative blurred colour orbs that drift down the page -->
      <div class="page-bg" aria-hidden="true">
        <span class="orb-a"></span>
        <span class="orb-b"></span>
        <span class="orb-c"></span>
        <span class="orb-d"></span>
        <span class="orb-e"></span>
        <span class="orb-f"></span>
      </div>

      <slot />
    </main>

    <Footer />

    <!-- ── Cookie consent + Google Analytics (G-J48L2HGTSJ) ──
         Analytics loads ONLY on sakyadhita.org (never on the preview)
         and ONLY after the visitor accepts. -->
    <div class="consent" id="consent-banner" role="dialog" aria-label="Cookie consent" hidden>
      <p>
        We'd like to use anonymous statistics (Google&nbsp;Analytics) to understand how the site
        is used. No personal data, only if you agree.
        <a href="/privacy">Learn more</a>
      </p>
      <div class="consent-actions">
        <button class="btn btn--primary btn--sm" id="consent-accept" type="button">Accept</button>
        <button class="btn btn--ghost btn--sm" id="consent-decline" type="button">Decline</button>
      </div>
    </div>

    <script>
      const GA_ID = 'G-J48L2HGTSJ'
      const PROD_HOSTS = ['sakyadhita.org', 'www.sakyadhita.org']
      const CONSENT_KEY = 'sakyadhita-consent'

      function loadAnalytics() {
        // The preview site never sends data — statistics start the day
        // the real domain points here.
        if (!PROD_HOSTS.includes(location.hostname)) return
        const s = document.createElement('script')
        s.async = true
        s.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`
        document.head.appendChild(s)
        ;(window as any).dataLayer = (window as any).dataLayer || []
        function gtag(..._args: any[]) {
          // eslint-disable-next-line prefer-rest-params
          ;(window as any).dataLayer.push(arguments)
        }
        gtag('js', new Date())
        gtag('config', GA_ID, { anonymize_ip: true })
      }

      const banner = document.getElementById('consent-banner')!
      const choice = localStorage.getItem(CONSENT_KEY)
      if (choice === 'granted') {
        loadAnalytics()
      } else if (!choice) {
        banner.hidden = false
      }
      document.getElementById('consent-accept')!.addEventListener('click', () => {
        localStorage.setItem(CONSENT_KEY, 'granted')
        banner.hidden = true
        loadAnalytics()
      })
      document.getElementById('consent-decline')!.addEventListener('click', () => {
        localStorage.setItem(CONSENT_KEY, 'denied')
        banner.hidden = true
      })
    </script>

    <style>
      /* Cookie consent bar */
      .consent {
        position: fixed;
        left: 16px; right: 16px;
        bottom: calc(16px + env(safe-area-inset-bottom, 0px));
        z-index: 1500;
        max-width: 680px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        box-shadow: var(--shadow-lg);
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 18px;
      }
      .consent p {
        flex: 1;
        font-size: 13.5px;
        line-height: 1.5;
        color: var(--ink-body);
      }
      .consent p a { color: var(--purple); font-weight: 600; }
      .consent-actions { display: flex; gap: 8px; flex: none; }
      @media (max-width: 560px) {
        .consent { flex-direction: column; align-items: stretch; text-align: center; gap: 12px; }
        .consent-actions { justify-content: center; }
      }
    </style>

    <style>
      /* Accessibility: hidden link that appears when keyboard users press Tab */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 200;
        background: var(--purple);
        color: #fff;
        padding: 12px 20px;
        border-radius: 0 0 10px 0;
        font-weight: 600;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
