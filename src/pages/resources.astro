---
/**
 * Resources landing page — the library hub linking to newsletters,
 * publications, stories, and Buddhist culture.
 *
 * NOTE: "Stories & Articles" and "Buddhist Culture" sections don't have
 * their own pages yet (dead links in the design too) — they currently
 * point to the nearest real page until that content is migrated.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import resourcesPage from '../data/pages/resources.json'
---

<BaseLayout
  title={resourcesPage.seo.title}
  description={resourcesPage.seo.description}
  active="resources"
  ogImage={resourcesPage.seo.ogImage}
>
  <div class="shell">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">Home</a><span class="sep">›</span><span>Resources</span>
    </nav>
  </div>

  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">{resourcesPage.hero.eyebrow}</div>
      <h1 class="h-display">{resourcesPage.hero.heading}</h1>
      <p class="lede">
        {resourcesPage.hero.lede}
      </p>
    </div>
  </section>

  <!-- 4 LIBRARY CARDS -->
  <section>
    <div class="shell">
      <div class="lib-grid">
        {resourcesPage.libraryCards.map((card) => (
          <a class="lib" href={card.href}>
            <div class="pic" style={`background-image:url('${card.img}')`}>
              <span class="count">{card.count}</span>
            </div>
            <div class="body">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <span class="cta">{card.ctaLabel}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED THIS MONTH -->
  <section>
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{resourcesPage.featured.eyebrow}</div>
        <h2 class="h-section">{resourcesPage.featured.heading}</h2>
      </div>
      <div class="feat-row">
        {resourcesPage.featured.cards.map((card) => (
          <article class="feat-cd">
            <div class="pic" style={`background-image:url('${card.img}')`}></div>
            <div class="body">
              <div class="eyebrow">{card.eyebrow}</div>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <a class="cta" href={card.href}>{card.ctaLabel}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style is:global>
    .lib-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
    }
    .lib {
      position: relative;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 16px;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 16px;
      min-height: 280px;
      transition: transform .15s, box-shadow .2s, border-color .15s;
      text-decoration: none;
      color: inherit;
    }
    .lib:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--lavender-2); }
    .lib .pic {
      background-size: cover; background-position: center;
      border-radius: 8px;
      position: relative;
    }
    .lib .pic .count {
      position: absolute; left: 16px; top: 16px;
      background: rgba(22,3,79,.78); color: #fff;
      padding: 6px 12px; border-radius: var(--r-pill);
      font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
    }
    .lib .body {
      padding: 16px 24px 20px;
      display: flex; flex-direction: column; gap: 12px; justify-content: center;
    }
    .lib h3 {
      font-family: var(--font-title); font-weight: 700;
      font-size: 28px; color: var(--ink); line-height: 1.1;
    }
    .lib p { font-size: 14.5px; color: var(--ink-body); line-height: 1.55; }
    .lib .cta { color: var(--purple); font-weight: 600; font-size: 14px; }

    .feat-row {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    }
    .feat-cd {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 16px;
      display: flex; flex-direction: column;
      transition: transform .15s, box-shadow .2s, border-color .15s;
    }
    .feat-cd:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .feat-cd .pic { aspect-ratio: 16/10; background-size: cover; background-position: center; border-radius: 8px; }
    .feat-cd .body { padding: 18px 6px 6px; display: flex; flex-direction: column; gap: 8px; }
    .feat-cd h3 { font-family: var(--font-title); font-weight: 700; font-size: 22px; color: var(--ink); line-height: 1.15; }
    .feat-cd p { font-size: 14px; color: var(--ink-body); line-height: 1.55; }
    .feat-cd .cta { color: var(--purple); font-weight: 600; font-size: 13.5px; margin-top: 4px; }

    @media (max-width: 880px) {
      .lib-grid { grid-template-columns: 1fr; }
      .feat-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .lib { grid-template-columns: 1fr; }
      .lib .pic { aspect-ratio: 16/10; }
      .lib .body { padding: 8px 4px 10px; }
    }
  </style>
</BaseLayout>
