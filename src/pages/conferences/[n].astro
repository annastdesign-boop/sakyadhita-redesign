---
/**
 * /conferences/1 … /conferences/20 — one real page per conference.
 * These addresses match the old website's structure (e.g. /conferences/19),
 * so existing links keep working.
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import ConferenceDetail from '../../components/ConferenceDetail.astro'
const modules = import.meta.glob('../../content/conferences/*.json', { eager: true })
const conferences = Object.values(modules).map((m: any) => m.default)

export function getStaticPaths() {
  const mods = import.meta.glob('../../content/conferences/*.json', { eager: true })
  return Object.values(mods).map((m: any) => ({ params: { n: String(m.default.n) } }))
}

const n = Number(Astro.params.n)
const c = conferences.find((x: any) => x.n === n)!
const ord = (num: number) => {
  const s = ['th', 'st', 'nd', 'rd']
  const v = num % 100
  return num + (s[(v - 20) % 10] || s[v] || s[0])
}
const heroImg = (c as any).heroImg ?? c.photos?.find((p: any) => p.f)?.f ?? '/assets/feat-conf.png'
---

<BaseLayout
  title={`${ord(n)} Conference (${c.year}) · Sakyadhita`}
  description={`${c.title}${(c as any).subtitle ? ' — ' + (c as any).subtitle : ''}. The ${ord(n)} Sakyadhita International Conference on Buddhist Women, ${c.loc}, ${c.year}.`}
  active="conferences"
  ogImage={heroImg}
>
  <ConferenceDetail n={n} />
</BaseLayout>
