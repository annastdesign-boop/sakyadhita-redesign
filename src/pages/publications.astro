          <div class="foot"><span class="src">SUNY Press</span><span class="lnk">View →</span></div>
        </a>
        <a class="book" href="https://www.amazon.com/Innovative-Buddhist-Women-Swimming-Routledge/dp/0700712534" target="_blank" rel="noopener noreferrer">
          <div class="cover grad bk2"><img class="cv-img" src="https://books.google.com/books/content?id=PYMnAAAAQBAJ&printsec=frontcover&img=1&zoom=1" alt="Innovative Buddhist Women cover" loading="lazy" onerror="this.remove()" /><span class="b-title">Innovative Women in Buddhism</span><span class="b-auth">Karma Lekshe Tsomo</span></div>
          <div class="foot"><span class="src">Routledge</span><span class="lnk">View →</span></div>
        </a>
        <a class="book" href="https://www.sunypress.edu/p-2949-buddhist-women-across-cultures.aspx" target="_blank" rel="noopener noreferrer">
