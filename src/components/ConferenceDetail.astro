---
/**
 * ConferenceDetail — sidebar archive + full detail view for one conference.
 * Used by /conferences (shows the upcoming one) and /conferences/[n].
 *
 * All content comes from src/data/conferences.json — edit there.
 * Unlike the prototype (which rendered everything with JavaScript),
 * every conference is a real page with a real address.
 */
const modules = import.meta.glob('../content/conferences/*.json', { eager: true })
const allConferences = Object.values(modules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => b.n - a.n)

interface Props {
  /** Conference number to display, e.g. 19 */
  n: number
}
const { n } = Astro.props

type Conf = {
  n: number
  year: string
  flag: string
  loc: string
  title: string
  dates: string
  host: string
  about: string
  upcoming?: boolean
  heroImg?: string
  heroFocus?: string
  thumb?: string
  noPhotoCredit?: boolean
  subtitle?: string
  video?: { yt?: string; file?: string; title?: string; caption?: string; thumb?: string }
  coverage?: any
  photos: { f?: string; yt?: string; caption: string; focus?: string }[]
  materialsVisible?: boolean
  materials?: { chip: string; title: string; file: string; note?: string }[]
  notice?: string
  ctaPrimary?: { label: string; href: string }
  ctaSecondary?: { label: string; href: string }
  callForPapers?: {
    title: string
    titleLine2?: string
    subtitle?: string
    intro: string
    formUrl: string
    formLabel?: string
    topicsHeading?: string
    topics: string[]
    deadlines: { date: string; label: string; detail: string }[]
    originality?: string
    allowedHeading?: string
    allowed: string[]
    notAllowedHeading?: string
    notAllowed: string[]
    disclosure?: string
    welcome?: string
    note?: string
    contactEmail?: string
  }
}

const list = allConferences as Conf[]
const c = (list.find((x) => x.n === n) ?? list[0]) as Conf

/** 1 → "1st", 2 → "2nd", 19 → "19th" */
const ord = (num: number) => {
  const s = ['th', 'st', 'nd', 'rd']
  const v = num % 100
  return num + (s[(v - 20) % 10] || s[v] || s[0])
}

const DECADES = [
  { label: 'Upcoming', test: (x: Conf) => !!x.upcoming },
  { label: '2020s', test: (x: Conf) => !x.upcoming && +x.year >= 2020 },
  { label: '2010s', test: (x: Conf) => +x.year >= 2010 && +x.year < 2020 },
  { label: '2000s', test: (x: Conf) => +x.year >= 2000 && +x.year < 2010 },
  { label: '1990s', test: (x: Conf) => +x.year >= 1990 && +x.year < 2000 },
  { label: '1980s', test: (x: Conf) => +x.year >= 1980 && +x.year < 1990 },
]

/** Compact place name for the sidebar, e.g. "Kuching" */
const shortLoc = (x: Conf) => x.loc.split('·').pop()!.split(',')[0].trim()

const heroUrl = c.heroImg ?? c.photos?.find((p) => p.f)?.f ?? ''
const coverageItems = c.coverage ? (Array.isArray(c.coverage) ? c.coverage : [c.coverage]) : null
const prevConfs = list.filter((x) => !x.upcoming && x.n !== c.n).slice(0, 3)
const prevThumb = (x: Conf) => x.thumb ?? x.photos?.find((p) => p.f)?.f ?? x.heroImg ?? ''
const nPhotos = c.photos?.filter((p) => !p.yt).length ?? 0
const nVideos = c.photos?.filter((p) => p.yt).length ?? 0

const placeholderMaterials = [
  { c1: '#BB8FDB', c2: '#773BFA', vol: c.year, ttl: 'Conference Brochure', file: `Conference Brochure ${c.year}`, chip: 'PROGRAM' },
  { c1: '#F39A6C', c2: '#DE7386', vol: 'SCHEDULE', ttl: 'Program at a glance', file: 'Full Program Schedule', chip: 'SCHEDULE' },
  { c1: '#16034F', c2: '#4F3E81', vol: 'PAPERS', ttl: 'Abstract Book', file: 'Abstract Book', chip: 'PAPERS' },
]
const realMaterials = c.materialsVisible && c.materials?.length ? c.materials : null
const MAT_COLORS = [
  ['#BB8FDB', '#773BFA'],
  ['#F39A6C', '#DE7386'],
  ['#16034F', '#4F3E81'],
  ['#DE7386', '#16034F'],
  ['#FAB2BE', '#BB8FDB'],
]
---

<div class="cd-layout">
  <!-- SIDEBAR — the conference archive -->
  <aside class="cd-side">
    <div class="cd-side-inner">
      <div class="brand-h">
        <div class="wm">SAKYADHITA</div>
        <div class="sub">Conference Archive · 19 events</div>
      </div>
      {
        DECADES.map((d) => {
          const items = list.filter(d.test)
          if (!items.length) return null
          return (
            <>
              <div class="cd-decade">{d.label}</div>
              {items.map((x) => (
                <a class:list={['cd-entry', { 'is-active': x.n === c.n }]} href={x.upcoming ? '/conferences' : `/conferences/${x.n}`}>
                  <div class="badge">#{x.n}</div>
                  <div class="info">
                    <div class="yr">{x.year}</div>
                    <div class="loc">{shortLoc(x)}</div>
                  </div>
                </a>
              ))}
            </>
          )
        })
      }
    </div>
  </aside>

  <!-- MAIN -->
  <div class="cd-main">
    <section class="cd-hero">
      <div class="col-text">
        {c.upcoming && <div class="upcoming-tag">COMING SOON</div>}
        <div class="badges">
          <span class="badge outlined">{ord(c.n).toUpperCase()} CONFERENCE</span>
          <span class="badge filled">{c.year}</span>
        </div>
        <h1>{c.title}</h1>
        {!c.upcoming && c.subtitle && <div class="subtitle">{c.subtitle}</div>}
        <div class="meta">
          <div class="meta-item"><span class="emoji">{c.flag}</span> {c.loc}</div>
          <div class="meta-item"><span class="emoji">🗓️</span> {c.dates}</div>
          <div class="meta-item"><span class="emoji">🤝</span> Hosted by {c.host}</div>
        </div>
        {c.notice && <p class="cd-notice">{c.notice}</p>}
        {
          (c.ctaPrimary?.label || c.ctaSecondary?.label) && (
            <div class="cd-ctas">
              {c.ctaPrimary?.label && (
                <a
                  class="btn btn--primary btn--lg"
                  href={c.ctaPrimary.href}
                  target={c.ctaPrimary.href.startsWith('http') ? '_blank' : undefined}
                  rel={c.ctaPrimary.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {c.ctaPrimary.label} <span class="arr">→</span>
                </a>
              )}
              {c.ctaSecondary?.label && (
                <a
                  class="btn btn--ghost btn--lg"
                  href={c.ctaSecondary.href}
                  target={c.ctaSecondary.href.startsWith('http') ? '_blank' : undefined}
                  rel={c.ctaSecondary.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {c.ctaSecondary.label}
                </a>
              )}
            </div>
          )
        }
      </div>
      <div
        class="pic"
        aria-hidden="true"
        style={heroUrl ? `background-image:url('${heroUrl}'); background-size:cover; background-position:${c.heroFocus || 'center'};` : undefined}
      >
      </div>
    </section>

    {
      c.callForPapers && (
        <section class="cfp" id="proposals">
          <div class="cfp-top">
            <div class="cfp-lead">
              <div class="cfp-head">
                <div class="eyebrow">CALL FOR PAPERS</div>
                <h2>
                  {c.callForPapers.title}
                  {c.callForPapers.titleLine2 && <span class="cfp-title-line2">{c.callForPapers.titleLine2}</span>}
                </h2>
                {c.callForPapers.subtitle && <p class="cfp-sub">{c.callForPapers.subtitle}</p>}
              </div>
              <p class="cfp-intro"><Fragment set:html={c.callForPapers.intro} /></p>
              <div class="cfp-cta cfp-cta--top">
                <a class="btn btn--primary btn--lg" href={c.callForPapers.formUrl} target="_blank" rel="noopener noreferrer">
                  {c.callForPapers.formLabel || 'Submit your proposal'} <span class="arr">→</span>
                </a>
                {c.callForPapers.contactEmail && (
                  <p class="cfp-contact">
                    Questions? Write to <a href={`mailto:${c.callForPapers.contactEmail}`}>{c.callForPapers.contactEmail}</a>
                  </p>
                )}
                {c.callForPapers.note && <p class="cfp-note">{c.callForPapers.note}</p>}
              </div>
            </div>

            {c.callForPapers.deadlines?.length > 0 && (
              <aside class="cfp-side">
                <h3 class="cfp-block-title">Key dates</h3>
                <div class="cfp-dates cfp-dates--stack">
                  {c.callForPapers.deadlines.map((dl) => (
                    <div class="cfp-date">
                      <div class="d">{dl.date}</div>
                      <div class="l">{dl.label}</div>
                      <p>{dl.detail}</p>
                    </div>
                  ))}
                </div>
              </aside>
            )}
          </div>

          {c.callForPapers.topics?.length > 0 && (
            <>
              <h3 class="cfp-block-title">{c.callForPapers.topicsHeading || 'Suggested topics'}</h3>
              <ol class="cfp-topics">
                {c.callForPapers.topics.map((t, i) => (
                  <li class="cfp-topic">
                    <span class="num">{i + 1}</span>
                    <span>{t}</span>
                  </li>
                ))}
              </ol>
            </>
          )}

          {(c.callForPapers.allowed?.length > 0 || c.callForPapers.notAllowed?.length > 0) && (
            <div class="cfp-rules">
              {c.callForPapers.originality && <p class="cfp-orig">{c.callForPapers.originality}</p>}
              <div class="cfp-ai">
                <div class="cfp-ai-col">
                  <h4>{c.callForPapers.allowedHeading || 'Allowed'}</h4>
                  <ul>
                    {c.callForPapers.allowed.map((a) => (
                      <li class="ok">
                        <span class="mark">✓</span>
                        <span>{a}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="cfp-ai-col">
                  <h4>{c.callForPapers.notAllowedHeading || 'Not allowed'}</h4>
                  <ul>
                    {c.callForPapers.notAllowed.map((a) => (
                      <li class="no">
                        <span class="mark">✕</span>
                        <span>{a}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
              {c.callForPapers.disclosure && (
                <p class="cfp-disclosure">
                  <span class="mark ok-mark">✓</span> {c.callForPapers.disclosure}
                </p>
              )}
            </div>
          )}

          {c.callForPapers.welcome && <p class="cfp-welcome">{c.callForPapers.welcome}</p>}

          <div class="cfp-cta">
            <a class="btn btn--primary btn--lg" href={c.callForPapers.formUrl} target="_blank" rel="noopener noreferrer">
              {c.callForPapers.formLabel || 'Submit your proposal'} <span class="arr">→</span>
            </a>
            {c.callForPapers.contactEmail && (
              <p class="cfp-contact">
                Questions? Write to <a href={`mailto:${c.callForPapers.contactEmail}`}>{c.callForPapers.contactEmail}</a>
              </p>
            )}
          </div>

        </section>
      )
    }

    {
      c.upcoming ? (
        <section class="about-card">
          <p>{c.about}</p>
          <p style="margin-top: 16px;">
            <strong>Registration will be opening soon.</strong>
          </p>
        </section>
      ) : (
        <section class="about-card">
          <h3>About the conference</h3>
          <p>{c.about}</p>
        </section>
      )
    }

    {
      !c.upcoming && (c.video?.yt || c.video?.file) && (
        <section class="conf-video">
          <div class="cv-head">
            <div class="eyebrow">{ord(c.n).toUpperCase()} INTERNATIONAL CONFERENCE</div>
            {c.video.title && <h2 class="cv-title">{c.video.title}</h2>}
          </div>
          {c.video.file ? (
            <video class="cv-stage cv-native" controls preload="metadata" poster={c.video.thumb} src={c.video.file}>
              Your browser can't play this video. <a href={c.video.file}>Download it instead.</a>
            </video>
          ) : (
            <div
              class="cv-stage"
              data-yt={c.video.yt}
              style={`background-image:url('${c.video.thumb ?? `https://img.youtube.com/vi/${c.video.yt}/maxresdefault.jpg`}');`}
            >
              {c.video.caption && <span class="cv-caption">{c.video.caption}</span>}
              <button class="cv-play" type="button" aria-label="Play video" />
            </div>
          )}
        </section>
      )
    }

    {
      !c.upcoming && c.photos?.length > 0 && (
        <section class="photos-block">
          <div class="photos-head">
            <div class="left">
              <span class="label" style="font-family: var(--font-title); font-weight: 700; font-size: 24px; color: var(--ink);">
                Photos &amp; video
              </span>
              {!c.noPhotoCredit && (
                <span class="photos-credit">
                  Big thank you for these beautiful photos to{' '}
                  <a href="https://www.olivieradam.net/" target="_blank" rel="noopener noreferrer">
                    Olivier Adam
                  </a>
                  .
                </span>
              )}
            </div>
            <div class="right">
              <span class="count">{nVideos ? `${nPhotos} photos · ${nVideos} video${nVideos > 1 ? 's' : ''}` : `${nPhotos} photos`}</span>
            </div>
          </div>
          <div class="carousel" id="photo-carousel">
            {c.photos.map((p) =>
              p.yt ? (
                <div
                  class="photo-tile video"
                  data-type="video"
                  data-yt={p.yt}
                  data-src={p.f ?? `https://img.youtube.com/vi/${p.yt}/hqdefault.jpg`}
                  data-caption={p.caption}
                  style={`background-image:url('${p.f ?? `https://img.youtube.com/vi/${p.yt}/hqdefault.jpg`}');`}
                >
                  <span class="v-badge">VIDEO</span>
                  <span class="play" />
                </div>
              ) : (
                <div class="photo-tile" data-type="image" data-src={p.f} data-caption={p.caption} style={`background-image:url('${p.f}');${p.focus ? ` background-position: ${p.focus};` : ''}`} />
              )
            )}
          </div>
          <button class="photos-more" id="photos-see-more" type="button">
            See more images →
          </button>
        </section>
      )
    }

    {
      !c.upcoming && (
        <section>
          <div class="panel-head">
            <span class="label">Media coverage</span>
          </div>
          <div class="coverage-list">
            {coverageItems ? (
              coverageItems.map((cv: any) => (
                <article class="h-card-row">
                  <div
                    class="thumb"
                    style={cv.img ? `background-image:url('${cv.img}');` : 'background: linear-gradient(135deg, var(--lavender), var(--coral-2));'}
                  />
                  <div class="body">
                    <div class="top-row">
                      <span class="outlet-tag">{cv.outlet}</span>
                      <span class="date">{cv.date}</span>
                    </div>
                    <div class="headline">{cv.headline}</div>
                    <p class="excerpt">{cv.excerpt}</p>
                    <a class="read-link" href={cv.href} target="_blank" rel="noopener noreferrer">
                      Read coverage ↗
                    </a>
                  </div>
                </article>
              ))
            ) : (
              <article class="h-card-row">
                <div
                  class="thumb"
                  style={
                    c.photos?.[0]?.f
                      ? `background-image:url('${c.photos[0].f}');`
                      : 'background: linear-gradient(135deg, var(--lavender), var(--coral-2));'
                  }
                />
                <div class="body">
                  <div class="top-row">
                    <span class="outlet-tag">SAKYADHITA NEWSLETTER</span>
                    <span class="date">{c.year}</span>
                  </div>
                  <div class="headline">
                    {ord(c.n)} Sakyadhita International Conference — {c.title}
                  </div>
                  <p class="excerpt">
                    Reflections and reports from the gathering in {shortLoc(c)}, {c.year}.
                  </p>
                  <a class="read-link" href="/newsletters">Read coverage ↗</a>
                </div>
              </article>
            )}
          </div>
        </section>
      )
    }

    {
      realMaterials && (
        <section>
          <div class="panel-head">
            <span class="label">Conference materials</span>
          </div>
          {realMaterials.map((m, i) => (
            <article class="h-card-row">
              <div class="thumb doc" style={`--c1:${MAT_COLORS[i % MAT_COLORS.length][0]}; --c2:${MAT_COLORS[i % MAT_COLORS.length][1]};`}>
                <div>
                  <div class="doc-vol">{m.chip}</div>
                  <div class="doc-ttl">{m.title}</div>
                </div>
              </div>
              <div class="body">
                <span class="chip">{m.chip}</span>
                <div class="file-title">{m.title}</div>
                <div class="file-meta">{m.note || 'PDF'}</div>
              </div>
              <a class="get" href={m.file} target="_blank" rel="noopener noreferrer">
                <svg class="dl-ico" viewBox="0 0 16 16" fill="none">
                  <path d="M8 2 L8 11 M4 7 L8 11 L12 7 M3 13 L13 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Download
              </a>
            </article>
          ))}
        </section>
      )
    }

    {
      !realMaterials && !c.upcoming && (
        <section>
          <div class="panel-head">
            <span class="label">Conference materials</span>
          </div>
          {placeholderMaterials.map((m) => (
            <article class="h-card-row">
              <div class="thumb doc" style={`--c1:${m.c1}; --c2:${m.c2};`}>
                <div>
                  <div class="doc-vol">{m.vol}</div>
                  <div class="doc-ttl">{m.ttl}</div>
                </div>
              </div>
              <div class="body">
                <span class="chip">{m.chip}</span>
                <div class="file-title">{m.file}</div>
                <div class="file-meta">Coming soon</div>
              </div>
              <button class="get" disabled style="opacity:.5; cursor:not-allowed;">
                <svg class="dl-ico" viewBox="0 0 16 16" fill="none">
                  <path d="M8 2 L8 11 M4 7 L8 11 L12 7 M3 13 L13 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Soon
              </button>
            </article>
          ))}
        </section>
      )
    }

    {
      prevConfs.length > 0 && (
        <section>
          <div class="panel-head">
            <span class="label">See previous conferences</span>
          </div>
          <div class="prev-grid">
            {prevConfs.map((x) => (
              <a class="prev-card" href={`/conferences/${x.n}`}>
                <div class="pic" style={prevThumb(x) ? `background-image:url('${prevThumb(x)}');` : undefined}>
                  <span class="num">#{x.n}</span>
                </div>
                <div class="body">
                  <div class="meta">
                    {x.year} · {shortLoc(x).toUpperCase()}
                  </div>
                  <h3>{x.title}</h3>
                  <span class="view">View conference →</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</div>

<!-- Lightbox (photo/video viewer) -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <div class="stage">
    <button class="close" id="lb-close" aria-label="Close">✕</button>
    <button class="nav prev" id="lb-prev" aria-label="Previous">←</button>
    <div class="media-slot" id="lb-slot"></div>
    <button class="nav next" id="lb-next" aria-label="Next">→</button>
    <div class="caption-bar"><div class="cap" id="lb-cap"></div></div>
    <div class="thumbs" id="lb-thumbs"></div>
  </div>
</div>

<script>
  // ── Lightbox + inline video player (ported from the design prototype) ──
  const lb: { items: { src: string; caption: string; yt: string }[]; idx: number; open: boolean } = {
    items: [],
    idx: 0,
    open: false,
  }
  const lbBox = () => document.getElementById('lightbox')

  function thumbs() {
    const el = document.getElementById('lb-thumbs')
    if (!el) return
    const counter = `<div class="counter">${lb.idx + 1} / ${lb.items.length}</div>`
    el.innerHTML =
      counter +
      lb.items
        .map((it, i) => `<button class="t ${i === lb.idx ? 'is-current' : ''}" data-i="${i}" style="background-image:url('${it.src}');"></button>`)
        .join('')
  }
  function show(i: number) {
    const slot = document.getElementById('lb-slot')
    const cap = document.getElementById('lb-cap')
    if (!slot) return
    lb.idx = (i + lb.items.length) % lb.items.length
    const it = lb.items[lb.idx]
    if (it.yt) {
      slot.innerHTML = `<iframe class="media-video" src="https://www.youtube.com/embed/${it.yt}?autoplay=1&rel=0" title="${it.caption}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`
    } else {
      slot.innerHTML = `<img class="media" src="${it.src}" alt="${it.caption}" />`
    }
    if (cap) cap.textContent = it.caption
    thumbs()
  }
  function openAt(i: number) {
    const b = lbBox()
    if (!b) return
    show(i)
    b.classList.add('is-open')
    lb.open = true
    document.body.style.overflow = 'hidden'
  }
  function closeLb() {
    const b = lbBox()
    if (!b) return
    b.classList.remove('is-open')
    const s = document.getElementById('lb-slot')
    if (s) s.innerHTML = ''
    lb.open = false
    document.body.style.overflow = ''
  }

  // Phones: load the conference video player directly so one tap plays it
  if (window.matchMedia('(max-width: 760px)').matches) {
    document.querySelectorAll('.cv-stage[data-yt]').forEach((cv) => {
      const el = cv as HTMLElement
      el.innerHTML = `<iframe class="cv-frame" src="https://www.youtube-nocookie.com/embed/${el.dataset.yt}?rel=0&playsinline=1" title="Conference highlights" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`
      el.classList.add('is-playing')
    })
  }

  document.addEventListener('click', (e) => {
    const target = e.target as Element
    const tile = target.closest('#photo-carousel .photo-tile') as HTMLElement | null
    if (tile) {
      const tiles = [...document.querySelectorAll('#photo-carousel .photo-tile')] as HTMLElement[]
      lb.items = tiles.map((t) => ({ src: t.dataset.src || '', caption: t.dataset.caption || '', yt: t.dataset.yt || '' }))
      openAt(tiles.indexOf(tile))
      return
    }
    if (target.closest('#photos-see-more')) {
      const tiles = [...document.querySelectorAll('#photo-carousel .photo-tile')] as HTMLElement[]
      lb.items = tiles.map((t) => ({ src: t.dataset.src || '', caption: t.dataset.caption || '', yt: t.dataset.yt || '' }))
      openAt(0)
      return
    }
    const cv = target.closest('.cv-stage') as HTMLElement | null
    if (cv && cv.dataset.yt && !cv.classList.contains('is-playing')) {
      cv.innerHTML = `<iframe class="cv-frame" src="https://www.youtube.com/embed/${cv.dataset.yt}?autoplay=1&rel=0" title="Conference highlights" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`
      cv.classList.add('is-playing')
      return
    }
    if (target.closest('#lb-prev')) { e.stopPropagation(); show(lb.idx - 1); return }
    if (target.closest('#lb-next')) { e.stopPropagation(); show(lb.idx + 1); return }
    if (target.closest('#lb-close')) { closeLb(); return }
    const th = target.closest('#lb-thumbs .t') as HTMLElement | null
    if (th) { show(parseInt(th.dataset.i || '0', 10)); return }
    if (e.target === lbBox()) { closeLb(); return }
  })
  document.addEventListener('keydown', (e) => {
    if (!lb.open) return
    if (e.key === 'Escape') closeLb()
    if (e.key === 'ArrowLeft') show(lb.idx - 1)
    if (e.key === 'ArrowRight') show(lb.idx + 1)
  })
</script>

