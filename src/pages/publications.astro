---
/**
 * Publications library — bibliographies, books, conference brochures,
 * membership brochures, and translated scholarship.
 *
 * ALL content comes from src/data/publications.json (editable in the
 * CMS — every card is an entry you can add/remove/reorder).
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import BookCard from '../components/BookCard.astro'
import brochurePanel from '../data/membership-brochures.json'
import groupOrder from '../data/publication-groups.json'

const modules = import.meta.glob('../content/publications/*.json', { eager: true })
const cards = Object.values(modules)
  .map((m: any) => m.default)
  .sort((a: any, b: any) => (a.sort ?? 0) - (b.sort ?? 0))

const bySection = (section: string) => cards.filter((c: any) => c.section === section)
const pubs = {
  bibliographies: bySection('bibliographies'),
  books: bySection('books'),
  conferenceBrochures: bySection('conference-brochures'),
  membershipBrochures: brochurePanel,
  translationGroups: groupOrder.order
    .map((heading: string) => ({
      heading,
      items: cards.filter((c: any) => c.section === 'translations' && c.group === heading),
    }))
    .filter((g: any) => g.items.length),
}
---

<BaseLayout
  title="Publications · Sakyadhita"
  description="Bibliographies, books, conference brochures, and translations on Buddhist women's lives, history, and scholarship — gathered over four decades by Sakyadhita. Free and open to all."
  active="resources"
  ogImage="/assets/publication.jpg"
>
  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">RESOURCES · PUBLICATIONS</div>
      <h1 class="h-display">A scholarly library of Buddhist women's lives and words</h1>
      <p class="lede">
        Bibliographies, books, conference brochures, and translations gathered over four decades —
        documenting the history, texts, and stories of Buddhist women across traditions. Free and
        open to all.
      </p>
    </div>
  </section>

  <section id="bibliographies">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">BIBLIOGRAPHIES</div>
        <h2 class="h-section">Five reading lists on Buddhist women</h2>
      </div>
      <div class="book-grid">
        {pubs.bibliographies.map((item) => <BookCard item={item} />)}
      </div>
    </div>
  </section>

  <section id="books" style="background: var(--bg-section);">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">BOOKS</div>
        <h2 class="h-section">Books by and about Buddhist women</h2>
      </div>
      <div class="book-grid">
        {pubs.books.map((item) => <BookCard item={item} />)}
      </div>
    </div>
  </section>

  <section id="conference-brochures">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">CONFERENCE BROCHURES</div>
        <h2 class="h-section">Programs from past conferences</h2>
      </div>
      <div class="carousel">
        <div class="carousel-track" id="conf-track">
          {pubs.conferenceBrochures.map((item) => <BookCard item={item} />)}
        </div>
        <div class="carousel-arrows">
          <button class="carousel-btn" id="conf-prev" aria-label="Previous">←</button>
          <button class="carousel-btn" id="conf-next" aria-label="Next">→</button>
        </div>
      </div>
    </div>
  </section>

  <section id="brochures" style="background: var(--bg-section);">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">MEMBERSHIP BROCHURES</div>
        <h2 class="h-section">Translated into {pubs.membershipBrochures.languages.length} languages</h2>
      </div>
      <div class="mbr">
        <div class="pic" style={`background-image:url('${pubs.membershipBrochures.image}')`}></div>
        <div class="langs">
          {
            pubs.membershipBrochures.languages.map((l) => (
              <a class="lang" href={l.pdf} target="_blank" rel="noopener noreferrer">
                <span class="l-left">
                  <span class="flag">{l.flag}</span>
                  <span class="l-name">{l.name}</span>
                </span>
                <span class="l-link">PDF →</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="translations">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">TRANSLATIONS &amp; ARTICLES</div>
        <h2 class="h-section">Scholarship in many languages</h2>
      </div>
      <div class="tr-stack">
        {
          pubs.translationGroups.map((group) => (
            <div class="tr-group">
              <div class="tr-head">{group.heading}</div>
              <div class="tr-cards">
                {group.items.map((item) => (
                  <a class="tr-card" href={item.href} target="_blank" rel="noopener noreferrer">
                    {item.kind && <div class="tr-kind">{item.kind}</div>}
                    <h3>{item.title}</h3>
                    <p>{item.author}{item.author && item.source ? ' · ' : ''}{item.source}</p>
                    <span class="link">{item.linkLabel}</span>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    // Conference-brochure carousel arrows
    const track = document.getElementById('conf-track')
    const prev = document.getElementById('conf-prev') as HTMLButtonElement | null
    const next = document.getElementById('conf-next') as HTMLButtonElement | null
    if (track && prev && next) {
      const step = () => {
        const card = track.querySelector('.book')
        return card ? card.getBoundingClientRect().width + 22 : 240
      }
      const update = () => {
        prev.disabled = track.scrollLeft <= 2
        next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2
      }
      prev.addEventListener('click', () => track.scrollBy({ left: -step() * 2, behavior: 'smooth' }))
      next.addEventListener('click', () => track.scrollBy({ left: step() * 2, behavior: 'smooth' }))
      track.addEventListener('scroll', update)
      window.addEventListener('resize', update)
      setTimeout(update, 100)
    }
  </script>

  <style is:global>
    main section { scroll-margin-top: 96px; }
    .site-footer { margin-top: 0; }
    #translations { padding-bottom: 56px; }

    /* Books — vertical cover cards */
    .book-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 22px;
    }
    .book {
      display: flex; flex-direction: column;
      text-decoration: none; color: inherit;
    }
    .book .cover {
      aspect-ratio: 4/5;
      border-radius: 8px;
      padding: 18px 16px;
      display: flex; flex-direction: column; justify-content: flex-end;
      box-shadow: var(--shadow-md);
      transition: transform .18s, box-shadow .2s;
      overflow: hidden;
      position: relative;
      min-height: 0;
    }
    .book .cover.photo { background-size: cover; background-position: center; background-color: var(--bg-section); }
    .book .cover.photo::after {
      content: ""; position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(to top, rgba(22,3,79,.88), rgba(22,3,79,.25) 55%, rgba(22,3,79,.05));
    }
    .book .cover.grad::before, .book .cover:not(.photo)::before {
      content: "";
      position: absolute; left: 0; right: 0; top: 0; height: 6px;
      background: rgba(255,255,255,.55);
    }
    .book:hover .cover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .book .cover .b-kind {
      font-family: var(--font-ui); font-weight: 600; font-size: 10.5px; letter-spacing: 0.14em;
      color: rgba(255,255,255,.9); margin-bottom: 8px; position: relative; z-index: 2;
    }
    .book .cover .b-title {
      font-family: var(--font-title); font-weight: 700;
      font-size: 17px; line-height: 1.18; color: #fff;
      text-wrap: balance; position: relative; z-index: 2;
      overflow-wrap: anywhere; word-break: break-word;
      display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden;
    }
    .book .cover .b-auth {
      font-family: var(--font-ui); font-weight: 500; font-size: 11.5px;
      color: rgba(255,255,255,.85); margin-top: 8px; position: relative; z-index: 2;
    }
    .book .foot {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 8px; padding: 12px 2px 0;
    }
    .book .foot .src { font-size: 12px; color: var(--ink-subtle); }
    .book .foot .lnk { color: var(--purple); font-weight: 600; font-size: 12.5px; white-space: nowrap; }
    .bk1 { background: linear-gradient(155deg, #773BFA, #16034F); }
    .bk2 { background: linear-gradient(155deg, #DE7386, #16034F); }
    .bk3 { background: linear-gradient(155deg, #F39A6C, #B5476A); }
    .bk4 { background: linear-gradient(155deg, #4F3E81, #16034F); }
    .bk5 { background: linear-gradient(155deg, #BB8FDB, #5E3AAE); }

    /* Real cover image layered over gradient fallback */
    .book .cover .cv-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; }
    .book .cover:has(.cv-img)::before { display: none; }
    .book .cover:has(.cv-img) .b-kind,
    .book .cover:has(.cv-img) .b-title,
    .book .cover:has(.cv-img) .b-auth { display: none; }

    /* Carousel */
    .carousel { position: relative; }
    .carousel-track {
      display: grid; grid-auto-flow: column;
      grid-auto-columns: calc((100% - 88px) / 5);
      gap: 22px; overflow-x: auto; scroll-behavior: smooth;
      scroll-snap-type: x mandatory; padding-bottom: 4px;
      scrollbar-width: none;
    }
    .carousel-track::-webkit-scrollbar { display: none; }
    .carousel-track .book { scroll-snap-align: start; }
    .carousel-arrows { display: flex; justify-content: center; gap: 14px; margin-top: 28px; }
    .carousel-btn {
      width: 46px; height: 46px; border-radius: 50%;
      border: 1px solid var(--border); background: #fff; color: var(--ink);
      font-size: 18px; cursor: pointer; display: grid; place-items: center;
      transition: background .15s, color .15s, border-color .15s;
    }
    .carousel-btn:hover { background: var(--purple); color: #fff; border-color: var(--purple); }
    .carousel-btn:disabled { opacity: .35; cursor: default; background: #fff; color: var(--ink); border-color: var(--border); }
    @media (max-width: 880px) { .carousel-track { grid-auto-columns: calc((100% - 22px) / 2); } }
    @media (max-width: 560px) { .carousel-track { grid-auto-columns: 78%; } }

    /* Membership brochures — split panel */
    .mbr {
      display: grid; grid-template-columns: 1.1fr 1fr; gap: 32px;
      background: #fff; border: 1px solid var(--border);
      border-radius: var(--r-lg); padding: 16px;
      align-items: stretch;
    }
    .mbr .pic {
      background-size: cover; background-position: center;
      background-color: var(--bg-section);
      border-radius: 8px; min-height: 520px;
    }
    .mbr .langs {
      display: flex; flex-direction: column; justify-content: center;
    }
    .mbr .lang {
      display: flex; align-items: center; justify-content: space-between; gap: 14px;
      padding: 15px 4px; border-bottom: 1px solid var(--border);
      text-decoration: none; color: inherit;
      transition: padding-left .15s;
    }
    .mbr .lang:last-child { border-bottom: 0; }
    .mbr .lang:hover { padding-left: 6px; }
    .mbr .lang:hover .l-name { color: var(--purple); }
    .mbr .lang .l-left { display: flex; align-items: center; gap: 14px; }
    .mbr .lang .flag { font-size: 26px; line-height: 1; }
    .mbr .lang .l-name { font-family: var(--font-title); font-weight: 700; font-size: 18px; color: var(--ink); transition: color .15s; }
    .mbr .lang .l-link { color: var(--purple); font-weight: 600; font-size: 13px; white-space: nowrap; }
    @media (max-width: 760px) {
      .mbr { grid-template-columns: 1fr; }
      .mbr .pic { min-height: 260px; }
    }

    /* Translations — simple text cards (like the Further-reading cards) */
    .tr-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .tr-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 24px;
      display: flex; flex-direction: column; gap: 10px;
      transition: transform .15s, border-color .15s;
      text-decoration: none; color: inherit;
    }
    .tr-card:hover { transform: translateY(-2px); border-color: var(--lavender-2); }
    .tr-card .tr-kind {
      font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--purple);
    }
    .tr-card h3 { font-family: var(--font-title); font-weight: 700; font-size: 20px; line-height: 1.25; color: var(--ink); }
    .tr-card p { font-size: 14px; color: var(--ink-body); line-height: 1.5; }
    .tr-card .link { color: var(--purple); font-weight: 600; font-size: 14px; margin-top: auto; }
    @media (max-width: 1100px) {
      .tr-cards { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 880px) {
      .tr-cards { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .tr-cards { grid-template-columns: 1fr; }
    }

    /* Translations — grouped columns */
    .tr-group .tr-head {
      font-family: var(--font-title); font-weight: 700; font-size: 19px;
      color: var(--ink); padding-bottom: 8px; margin-bottom: 18px;
      border-bottom: 2px solid var(--purple);
    }
    .tr-stack { display: flex; flex-direction: column; gap: 72px; }

    @media (max-width: 1100px) {
      .book-grid { grid-template-columns: repeat(4, 1fr); }
    }
    @media (max-width: 880px) {
      .book-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 560px) {
      .book-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</BaseLayout>
