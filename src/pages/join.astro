---
/**
 * Join / Membership page — benefits, tiers, and the membership form
 * (a real Netlify Form named "membership").
 *
 * NOTE: the PayPal payment step is NOT wired yet — submissions are
 * safely recorded in Netlify → Forms → "membership", and the thank-you
 * message explains payment instructions will follow. Connecting the
 * live PayPal checkout is a separate, deliberate step.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import joinPage from '../data/pages/join.json'

/* Benefit-card icons stay in code — matched to the cards in join.json by order. */
const benefitIcons = [
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h11v14H5a1 1 0 0 1-1-1V5z"/><path d="M15 8h3a1 1 0 0 1 1 1v8a2 2 0 0 1-2 2"/><line x1="7" y1="8.5" x2="12" y2="8.5"/><line x1="7" y1="11.5" x2="12" y2="11.5"/><line x1="7" y1="14.5" x2="10" y2="14.5"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1a2 2 0 0 0 0 4v1a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-1a2 2 0 0 0 0-4V8z"/><line x1="14" y1="6.5" x2="14" y2="17.5" stroke-dasharray="2 2.4"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="14" rx="2"/><path d="M8.5 12l2.2 2.2L15.5 9.5"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M4 12h16"/><path d="M12 4c2.6 2.2 2.6 13.8 0 16M12 4c-2.6 2.2-2.6 13.8 0 16"/></svg>',
]
---

<BaseLayout
  title={joinPage.seo.title}
  description={joinPage.seo.description}
  active="get-involved"
  ogImage={joinPage.seo.ogImage}
>
  <section class="hero-compact">
    <div class="shell">
      <div class="eyebrow">{joinPage.hero.eyebrow}</div>
      <h1 class="h-display">{joinPage.hero.title}</h1>
      <p class="lede" style="max-width: 500px; margin-left: auto; margin-right: auto;">{joinPage.hero.lede}</p>
      <div style="display: flex; gap: 12px; justify-content: center; margin-top: 24px;">
        <a class="btn btn--primary btn--lg" href="#join-form">{joinPage.hero.buttonLabel}</a>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section>
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{joinPage.benefits.eyebrow}</div>
        <h2 class="h-section">{joinPage.benefits.heading}</h2>
      </div>
      <div class="benefits-grid">
        {
          joinPage.benefits.cards.map((card, i) => (
            <div class="benefit">
              <div class="ico" set:html={benefitIcons[i]} />
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- TIERS -->
  <section class="tiers">
    <div class="shell">
      <div class="section-head">
        <h2 class="h-section">{joinPage.tiers.heading}</h2>
        <p class="muted" style="max-width: 62ch;">{joinPage.tiers.text}</p>
      </div>
      <div class="tier-groups">
        {
          joinPage.tiers.groups.map((group) => (
            <div class="tier-group">
              <div class="gh"><h3>{group.heading}</h3><span class="freq">{group.freq}</span></div>
              {group.note && <p class="g-note">{group.note}</p>}
              {group.lines.map((line) => (
                <div class="tier-line">
                  <div class="amt">{line.amt}</div>
                  <div class="who"><div class="w-title">{line.title}</div><div class="w-sub">{line.sub}</div></div>
                </div>
              ))}
            </div>
          ))
        }
      </div>
      <div class="tier-actions">
        <a class="btn btn--primary btn--lg" href="#join-form">{joinPage.tiers.buttonLabel}</a>
      </div>
    </div>
  </section>

  <!-- FORM -->
  <section class="form-section" id="join-form">
    <div class="shell">
      <div class="section-head">
        <div class="eyebrow">{joinPage.formHead.eyebrow}</div>
        <h2 class="h-section">{joinPage.formHead.heading}</h2>
      </div>

      <form class="form-card" name="paidmembership" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
        <input type="hidden" name="form-name" value="paidmembership" />
        <p hidden aria-hidden="true">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>

        <div class="field" style="margin-bottom: 6px;"><label>Membership tier *</label></div>
        <div class="tier-pick">
          <button type="button" class="tier-opt sel" data-name="Regular member ($30/year)" data-price="30" data-kind="subscription" data-plan="regular"><span class="o-amt">$30 <small>/year</small></span><span class="o-text"><span class="o-name">Regular member</span><span class="o-sub">Laypeople &amp; supporters</span></span></button>
          <button type="button" class="tier-opt" data-name="Reduced rate ($15/year)" data-price="15" data-kind="subscription" data-plan="reduced"><span class="o-amt">$15 <small>/year</small></span><span class="o-text"><span class="o-name">Reduced rate</span><span class="o-sub">Nuns, students, unemployed</span></span></button>
          <button type="button" class="tier-opt" data-name="Lifetime — Laypeople ($300)" data-price="300" data-kind="onetime"><span class="o-amt">$300 <small>once</small></span><span class="o-text"><span class="o-name">Lifetime · Laypeople</span><span class="o-sub">Paid once</span></span></button>
          <button type="button" class="tier-opt" data-name="Lifetime — Monastics ($150)" data-price="150" data-kind="onetime"><span class="o-amt">$150 <small>once</small></span><span class="o-text"><span class="o-name">Lifetime · Monastics</span><span class="o-sub">Paid once</span></span></button>
        </div>
        <input type="hidden" id="tier-value" name="membershipType" value="Regular member ($30/year)" />
        <!-- Filled automatically: tier price + optional donation. The PayPal
             transaction id is filled once the PayPal checkout is connected. -->
        <input type="hidden" id="total-paid" name="totalPaid" value="30" />
        <input type="hidden" name="payPalTransactionId" value="" />

        <div class="stack-4">
          <div class="form-row">
            <div class="field"><label for="j-fname">First name *</label><input id="j-fname" name="fName" type="text" required placeholder="First name" autocomplete="given-name" /></div>
            <div class="field"><label for="j-lname">Last name *</label><input id="j-lname" name="lName" type="text" required placeholder="Last name" autocomplete="family-name" /></div>
          </div>
          <div class="field"><label for="j-email">Email address *</label><input id="j-email" name="email" type="email" required placeholder="you@email.com" autocomplete="email" /></div>
          <div class="form-row">
            <div class="field"><label for="j-country">Country *</label><input id="j-country" name="country" type="text" required placeholder="Country" autocomplete="country-name" /></div>
            <div class="field"><label for="j-city">City</label><input id="j-city" name="city" type="text" placeholder="City" autocomplete="address-level2" /></div>
          </div>
          <div class="field">
            <label for="j-tradition">Buddhist tradition (optional)</label>
            <select id="j-tradition" name="tradition">
              <option>—</option>
              <option>Theravada</option>
              <option>Mahayana</option>
              <option>Vajrayana</option>
              <option>Other</option>
              <option>Prefer not to say</option>
            </select>
          </div>

          <div class="field">
            <label for="j-about">Tell us about yourself or your interests (optional)</label>
            <textarea
              id="j-about"
              name="about"
              rows="3"
              placeholder="Your practice, research, volunteering interests — anything you'd like to share"></textarea>
          </div>


          <label class="check">
            <input type="checkbox" name="consent" required />
            <span>I agree to receive Sakyadhita communications. I can unsubscribe at any time.</span>
          </label>
        </div>

        <div class="submit-row">
          <button type="submit" class="btn btn--primary btn--lg">{joinPage.formHead.submitLabel} <span class="arr">→</span></button>
        </div>
      </form>
    </div>
  </section>

  <!-- PayPal payment modal -->
  <div class="pay-modal" id="pay-modal" aria-hidden="true">
    <div class="pay-backdrop" data-close></div>
    <div class="pay-card" role="dialog" aria-modal="true" aria-labelledby="pay-title">
      <button class="pay-x" type="button" data-close aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="eyebrow" style="text-align:center;">{joinPage.payModal.eyebrow}</div>
      <h2 id="pay-title">{joinPage.payModal.title}</h2>
      <p class="pay-amount">Total: <b id="pay-amount-value">$30</b> USD</p>
      <div id="paypal-button-container"></div>
      <p class="pay-note">{joinPage.payModal.note}</p>
      <p class="pay-error" id="pay-error" role="alert" hidden></p>
    </div>
  </div>

  <!-- NEWSLETTER -->
  <section class="renew" id="newsletter" style="margin-bottom: 0;">
    <div class="shell shell--narrow">
      <div class="eyebrow">{joinPage.newsletter.eyebrow}</div>
      <h2 class="h-section" style="margin: 12px 0 6px;">{joinPage.newsletter.heading}</h2>
      <p class="muted" style="margin-bottom: 18px;">{joinPage.newsletter.text}</p>
      <form class="el-form" id="join-newsletter" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" style="max-width: 480px; margin: 0 auto;">
        <input type="hidden" name="form-name" value="newsletter" />
        <p hidden aria-hidden="true"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <input type="text" name="fullName" required placeholder="Your name" aria-label="Full name" style="flex: 1 1 100%;" />
        <input type="email" name="email" required placeholder="you@email.com" aria-label="Email address" />
        <button type="submit" class="btn btn--primary">{joinPage.newsletter.buttonLabel}</button>
      </form>
    </div>
  </section>

  <script type="application/json" id="join-copy" set:html={JSON.stringify(joinPage.success)} />
  <script>
    import { validateForm } from '../scripts/forms'

    /** Editable thank-you copy (from src/data/pages/join.json). */
    const joinCopy = JSON.parse(document.getElementById('join-copy')?.textContent || '{}')

    /**
     * Membership payment flow:
     * 1. Validate the form (inline errors if something's missing)
     * 2. Open the PayPal modal
     *    - Annual tiers ($30 / $15): PayPal SUBSCRIPTION — auto-renews
     *      every year until the member cancels in their PayPal account
     *    - Lifetime tiers ($300 / $150): ONE-TIME payment
     * 3. PayPal confirms → membership recorded in Netlify Forms
     *    ("paidmembership") with the PayPal reference id
     *
     * Payments land in whichever PayPal account issued the Client ID —
     * i.e. Sakyadhita's own account, which they manage.
     *
     * ⚠️ TO GO LIVE, fill in these three values from Sakyadhita's
     * PayPal account (all public-safe):
     * 1. PAYPAL_CLIENT_ID — developer.paypal.com → Apps & Credentials
     *    → Live → the app's Client ID.
     *    'sb' = demo mode: buttons render, payments are simulated.
     *    (The old site's id was deactivated by PayPal:
     *    AT0I6Qa0JYVBvlExcrLDBJAY3oqylXV_pIIn471l6C289hFh7E19i46YhR5G3Nq9mYyZ8v4u3m_m)
     * 2./3. PLAN_IDS — two yearly billing plans (P-XXXX…) created in
     *    the PayPal business dashboard: Pay & Get Paid → Subscriptions
     *    → Create plan ("Regular membership" $30/year and "Reduced
     *    membership" $15/year, both: billed yearly, until cancelled).
     * Until the plan ids are filled in, annual tiers are charged as a
     * one-time payment for the first year (clearly worded).
     */
    const PAYPAL_CLIENT_ID =
      'Acq4TEmNP2L7Mc5wvxFh1fkVR8k-aSJTfvseCUoqoCQNMoPgV9_f7NXVQm30zIjKSQpuXjygWnzmqf0u' // Live — Sakyadhita's account (from the business dashboard)
    const PLAN_IDS: Record<string, string> = {
      regular: 'P-5RK859658U385400MNJGW5OA', // Regular member $30/year (yearly, auto-renews)
      reduced: 'P-2F65167289358442JNJHCNVI', // Reduced rate $15/year (yearly, auto-renews)
    }
    const IS_DEMO = PAYPAL_CLIENT_ID === 'sb'

    const form = document.querySelector('form[name="paidmembership"]') as HTMLFormElement
    const modal = document.getElementById('pay-modal')!
    const payError = document.getElementById('pay-error')!
    const amountLabel = document.getElementById('pay-amount-value')!
    let recording = false

    /** Details of the currently selected tier. */
    function currentTier() {
      const sel = document.querySelector('.tier-opt.sel') as HTMLElement
      const price = Number(sel?.dataset.price || 0)
      const planKey = sel?.dataset.plan || ''
      const isSubscription = sel?.dataset.kind === 'subscription' && !!PLAN_IDS[planKey]
      return {
        price,
        planId: PLAN_IDS[planKey] || '',
        isSubscription,
        wantsYearly: sel?.dataset.kind === 'subscription',
        name: sel?.dataset.name || '',
      }
    }

    function openModal() {
      const t = currentTier()
      amountLabel.textContent = t.wantsYearly ? `$${t.price} / year` : `$${t.price}`
      payError.hidden = true
      const amountNote = document.getElementById('pay-renew-note')
      if (amountNote) amountNote.remove()
      if (t.wantsYearly) {
        const n = document.createElement('p')
        n.id = 'pay-renew-note'
        n.className = 'pay-note'
        n.textContent = t.isSubscription
          ? 'Renews automatically every year. Cancel anytime in your PayPal account — or email service.sakyadhita@gmail.com and we will cancel it for you.'
          : 'Covers your first year of membership. We will remind you when it is time to renew.'
        amountLabel.closest('.pay-amount')!.insertAdjacentElement('afterend', n)
      }
      if (IS_DEMO && !document.getElementById('demo-note')) {
        const note = document.createElement('p')
        note.id = 'demo-note'
        note.className = 'pay-note'
        note.style.cssText = 'background: var(--bg-warm); border-radius: 10px; padding: 10px 12px; color: var(--ink-2);'
        note.textContent = 'Preview mode: PayPal is in demo mode — no real money moves until the organization’s PayPal Client ID is added.'
        document.getElementById('paypal-button-container')!.insertAdjacentElement('beforebegin', note)
      }
      modal.classList.add('is-open')
      modal.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }
    function closeModal() {
      modal.classList.remove('is-open')
      modal.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
    }
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeModal))
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal()
    })

    function showPayError(msg: string) {
      payError.textContent = msg
      payError.hidden = false
    }

    /** Save the confirmed membership into Netlify Forms. */
    async function recordMembership(transactionId: string, paidValue: string) {
      const txInput = form.querySelector('input[name="payPalTransactionId"]') as HTMLInputElement
      const totalInput = document.getElementById('total-paid') as HTMLInputElement
      txInput.value = transactionId
      if (paidValue) totalInput.value = paidValue

      const data = new FormData(form)
      const body = new URLSearchParams()
      data.forEach((v, k) => body.append(k, String(v)))
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString(),
      })
      if (!res.ok) throw new Error(`Recording failed (${res.status})`)
    }

    function showSuccess(referenceId: string, opts: { yearly: boolean }) {
      closeModal()
      const panel = document.createElement('div')
      panel.className = 'form-success'
      panel.setAttribute('role', 'status')
      const demoLine = IS_DEMO
        ? '<p style="margin-top:10px; font-size:13px; color:var(--ink-subtle);">Demo mode — no payment was made and nothing was recorded.</p>'
        : ''
      const renewLine = opts.yearly
        ? '<p style="margin-top:8px;">Your membership renews automatically each year — you can cancel anytime in your PayPal account.</p>'
        : ''
      panel.innerHTML = `
        <div class="fs-icon" aria-hidden="true">🪷</div>
        <h3>${joinCopy.title || 'Welcome to Sakyadhita!'}</h3>
        <p>${joinCopy.text || 'Your payment was received and your membership is confirmed. PayPal has emailed you a receipt.'}</p>
        ${renewLine}${demoLine}
        <p style="margin-top:10px; font-size:13px; color:var(--ink-subtle);">Payment reference: ${referenceId}</p>`
      form.style.display = 'none'
      form.insertAdjacentElement('afterend', panel)
      panel.scrollIntoView({ behavior: 'smooth', block: 'center' })
    }

    /**
     * PayPal SDK loading. Subscriptions and one-time payments need the
     * SDK in different modes, so each mode loads under its own name.
     */
    const sdkCache: Record<string, Promise<any>> = {}
    function loadSdk(mode: 'orders' | 'subs'): Promise<any> {
      if (!sdkCache[mode]) {
        sdkCache[mode] = new Promise((resolve, reject) => {
          const ns = mode === 'subs' ? 'paypalSubs' : 'paypalOrders'
          const params =
            mode === 'subs'
              ? `client-id=${PAYPAL_CLIENT_ID}&currency=USD&intent=subscription&vault=true`
              : `client-id=${PAYPAL_CLIENT_ID}&currency=USD&intent=capture`
          const s = document.createElement('script')
          s.src = `https://www.paypal.com/sdk/js?${params}`
          s.setAttribute('data-namespace', ns)
          s.onload = () => {
            const sdk = (window as any)[ns]
            sdk ? resolve(sdk) : reject(new Error('PayPal failed to load'))
          }
          s.onerror = () => reject(new Error('PayPal failed to load'))
          document.head.appendChild(s)
        })
      }
      return sdkCache[mode]
    }

    /** What to do when payment succeeded but our recording failed. */
    function recordingFailed(refId: string) {
      showPayError(
        `Your payment succeeded (reference ${refId}) but our system couldn't record it. Please email service.sakyadhita@gmail.com with your PayPal receipt so we can register your membership.`
      )
    }

    /** Render the right PayPal buttons for the currently selected tier. */
    async function renderButtons() {
      const t = currentTier()
      const container = document.getElementById('paypal-button-container')!
      container.innerHTML = ''

      if (t.isSubscription) {
        // ── Annual membership: auto-renewing yearly subscription ──
        const sdk = await loadSdk('subs')
        await sdk
          .Buttons({
            createSubscription: (_data: any, actions: any) => actions.subscription.create({ plan_id: t.planId }),
            onApprove: async (data: any) => {
              const subId = data?.subscriptionID || ''
              if (!IS_DEMO) {
                try {
                  await recordMembership(subId, String(t.price))
                } catch {
                  recordingFailed(subId)
                  return
                }
              }
              showSuccess(subId, { yearly: true })
            },
            onError: () => showPayError('Something went wrong starting the payment. Please close this window and try again.'),
            onCancel: () => {},
          })
          .render('#paypal-button-container')
      } else {
        // ── Lifetime tiers (and annual until the yearly plans are
        //    created in PayPal): one-time payment ──
        const total = t.price
        const sdk = await loadSdk('orders')
        await sdk
          .Buttons({
            createOrder: (_data: any, actions: any) =>
              actions.order.create({
                purchase_units: [
                  {
                    description: `Sakyadhita membership — ${t.name}`,
                    amount: { currency_code: 'USD', value: total.toFixed(2) },
                  },
                ],
              }),
            onApprove: async (_data: any, actions: any) => {
              try {
                const details = await actions.order.capture()
                const capture = details?.purchase_units?.[0]?.payments?.captures?.[0]
                const txId = capture?.id || details?.id || ''
                const paid = capture?.amount?.value || String(total)
                if (!IS_DEMO) {
                  try {
                    await recordMembership(txId, paid)
                  } catch {
                    recordingFailed(txId)
                    return
                  }
                }
                showSuccess(txId, { yearly: false })
              } catch (err: any) {
                if (err?.details?.[0]?.issue === 'INSTRUMENT_DECLINED') return actions.restart()
                showPayError('The payment could not be completed. Please try again or use a different payment method.')
              }
            },
            onError: () => showPayError('Something went wrong starting the payment. Please close this window and try again.'),
            onCancel: () => {},
          })
          .render('#paypal-button-container')
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      if (recording) return
      if (!validateForm(form)) return
      openModal()
      try {
        // The embedded PayPal buttons render inside the popup — annual
        // tiers as a yearly subscription, lifetime tiers as a one-time
        // payment. Needs a valid PayPal Client ID.
        await renderButtons()
      } catch {
        showPayError(
          'Online payment is temporarily unavailable. Please email service.sakyadhita@gmail.com and we will help you complete your membership.'
        )
      }
    })

    // Membership tier picker — also keeps the totalPaid amount up to date
    const opts = [...document.querySelectorAll('.tier-opt')]
    const hidden = document.getElementById('tier-value') as HTMLInputElement | null
    const totalPaid = document.getElementById('total-paid') as HTMLInputElement | null

    opts.forEach((opt) => {
      opt.addEventListener('click', () => {
        opts.forEach((o) => o.classList.remove('sel'))
        opt.classList.add('sel')
        if (hidden) hidden.value = (opt as HTMLElement).dataset.name || ''
        if (totalPaid) totalPaid.value = (opt as HTMLElement).dataset.price || '0'
      })
    })

    // Newsletter placeholder (until a real mailing list is connected)
    const nl = document.getElementById('join-newsletter') as HTMLFormElement | null
    nl?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const btn = nl.querySelector('button')!
      const input = nl.querySelector('input[name="email"]') as HTMLInputElement
      btn.textContent = '…'
      try {
        const data = new FormData(nl)
        const body = new URLSearchParams()
        data.forEach((v, k) => body.append(k, String(v)))
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        })
        if (!res.ok) throw new Error()
        input.value = ''
        btn.textContent = 'Thanks ✓'
      } catch {
        btn.textContent = 'Try again'
        setTimeout(() => (btn.textContent = 'Subscribe'), 2500)
      }
    })
  </script>

  <style is:global>
    #join-form, #renew { scroll-margin-top: 96px; }
    .benefits-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    .benefit {
      padding: 28px 22px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      display: flex; flex-direction: column; gap: 10px;
      transition: transform .15s, box-shadow .2s;
    }
    .benefit:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .benefit .ico {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: var(--lavender);
      color: var(--purple);
      display: grid; place-items: center;
    }
    .benefit .ico svg { width: 24px; height: 24px; display: block; }
    .benefit h3 { font-family: var(--font-title); font-weight: 700; font-size: 22px; color: var(--ink); }
