---
/**
 * Footer — gradient footer with brand, link columns, social icons,
 * and a newsletter signup box.
 * All text and links live in src/data/footer.json (editable in the CMS).
 *
 * NOTE: the newsletter box is not wired to a real mailing list yet.
 */
import footer from '../data/footer.json'
const year = new Date().getFullYear()

const ICONS: Record<string, string> = {
  facebook: '<path d="M14 9h3l.4-3H14V4.2c0-.85.25-1.45 1.5-1.45H17V.1C16.7.05 15.8 0 14.7 0 12.4 0 10.8 1.4 10.8 4v2H8v3h2.8v8H14V9z"/>',
  youtube: '<path d="M23.5 6.5a3 3 0 0 0-2.1-2.1C19.5 4 12 4 12 4s-7.5 0-9.4.4A3 3 0 0 0 .5 6.5C.1 8.4.1 12 .1 12s0 3.6.4 5.5a3 3 0 0 0 2.1 2.1C4.5 20 12 20 12 20s7.5 0 9.4-.4a3 3 0 0 0 2.1-2.1c.4-1.9.4-5.5.4-5.5s0-3.6-.4-5.5zM9.6 15.5v-7l6.3 3.5-6.3 3.5z"/>',
  pinterest: '<path d="M12 0C5.4 0 0 5.4 0 12c0 5 3.1 9.3 7.5 11-.1-.9-.2-2.4 0-3.4l1.4-5.9s-.4-.7-.4-1.8c0-1.6.95-2.8 2.1-2.8 1 0 1.5.75 1.5 1.65 0 1-.65 2.5-.95 3.9-.3 1.15.6 2.1 1.7 2.1 2 0 3.6-2.15 3.6-5.2 0-2.7-1.95-4.6-4.7-4.6-3.2 0-5.1 2.4-5.1 4.9 0 .95.35 2 .85 2.55.1.1.1.2.1.3l-.3 1.3c0 .2-.15.3-.35.15-1.3-.6-2.1-2.5-2.1-4 0-3.3 2.4-6.3 6.9-6.3 3.6 0 6.4 2.6 6.4 6 0 3.6-2.25 6.5-5.4 6.5-1.05 0-2.05-.55-2.4-1.2l-.65 2.5c-.25.9-.9 2.05-1.3 2.75 1 .3 2.05.45 3.15.45 6.6 0 12-5.4 12-12S18.6 0 12 0z"/>',
  blog: '<path d="M21.976 24H2.026C.9 24 0 23.1 0 21.976V2.026C0 .9.9 0 2.026 0h19.95C23.1 0 24 .9 24 2.026v19.95C24 23.1 23.1 24 21.976 24zM12.154 5.5H9.5C7.29 5.5 5.5 7.29 5.5 9.5v5c0 2.21 1.79 4 4 4h5c2.21 0 4-1.79 4-4v-2.846c0-.637-.517-1.154-1.154-1.154h-.847c-.581 0-1.06-.435-1.135-1.008C15.096 6.633 13.803 5.5 12.154 5.5zM9.6 8.5h2c.552 0 1 .448 1 1s-.448 1-1 1h-2c-.552 0-1-.448-1-1s.448-1 1-1zm4.8 7H9.6c-.552 0-1-.448-1-1s.448-1 1-1h4.8c.552 0 1 .448 1 1s-.448 1-1 1z"/>',
  goodreads: '<path d="M11.43 23.995c-3.608-.208-6.274-2.077-6.448-5.078.695.007 1.416-.013 2.078.006.224 1.6 1.626 2.792 3.583 3.107 2.634.415 5.652-.297 6.098-3.983.264-2.184.03-3.183.03-4.196v-.35c-.941 2.29-2.746 3.583-5.28 3.583C7.256 17.077 4.5 13.7 4.5 9.75 4.5 5.752 7.36 2.42 11.62 2.42c2.634 0 4.196 1.334 5.15 3.35V2.72h1.977v13.834c0 4.802-2.516 7.19-7.31 7.44zm.204-19.622c-3.325 0-5.15 2.72-5.15 5.436 0 2.912 1.66 5.494 5.05 5.494 3.42 0 5.15-2.71 5.15-5.494 0-2.912-1.66-5.436-5.05-5.436z"/>',
}
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="brand" href="/" style="color:var(--ink);">
          <span class="mark" aria-hidden="true"></span>
          <span class="wordmark">Sakyadhita</span>
        </a>
        <p>{footer.blurb}</p>
        <div class="social" aria-label="Social media">
          {
            footer.social.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" title={s.label} aria-label={s.label}>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={ICONS[s.icon] || ''} />
              </a>
            ))
          }
        </div>
      </div>
      {
        footer.columns.map((col, i) => (
          <div class="footer-col">
            <h4>{col.title}</h4>
            <ul>
              {col.links.map((l) => (
                <li>
                  <a href={l.href}>{l.label}</a>
                </li>
              ))}
              {i === footer.columns.length - 1 && <li set:html={footer.address} />}
            </ul>
          </div>
        ))
      }
      <div class="footer-news">
        <h4>{footer.newsletter.title}</h4>
        <p>{footer.newsletter.text}</p>
        <form id="footer-newsletter" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="newsletter" />
          <p hidden aria-hidden="true"><label>Don't fill this out: <input name="bot-field" /></label></p>
          <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-rule"></div>
    <div class="footer-bottom">
      <span>© {year} <Fragment set:html={footer.bottomText} /></span>
      <a href="/privacy">Privacy</a>
    </div>
  </div>
</footer>

<script>
  // Newsletter signups are saved to Netlify → Forms → "newsletter".
  const form = document.getElementById('footer-newsletter') as HTMLFormElement | null
  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const btn = form.querySelector('button')!
    const input = form.querySelector('input[name="email"]') as HTMLInputElement
    if (!input.value) return
    const original = btn.textContent
    btn.textContent = '…'
    try {
      const data = new FormData(form)
      const body = new URLSearchParams()
      data.forEach((v, k) => body.append(k, String(v)))
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString(),
      })
      if (!res.ok) throw new Error()
      input.value = ''
      btn.textContent = 'Thanks ✓'
    } catch {
      btn.textContent = 'Try again'
      setTimeout(() => (btn.textContent = original), 2500)
    }
  })
</script>
